            </enumerator>
            <enumerator name="linear dodge" code="Bmld" description="Linear Dodge">
                <cocoa string-value="linearDodge"/>
            </enumerator>
            <enumerator name="lighter color" code="Bmlc" description="Lighter Color">
                <cocoa string-value="lighterColor"/>
            </enumerator>
            <enumerator name="overlay" code="Bmor" description="Overlay">
                <cocoa string-value="overlay"/>
            </enumerator>
            <enumerator name="soft light" code="Bmsl" description="Soft Light">
                <cocoa string-value="softLight"/>
            </enumerator>
            <enumerator name="hard light" code="Bmhl" description="Hard Light">
                <cocoa string-value="hardLight"/>
            </enumerator>
            <enumerator name="vivid light" code="Bmvl" description="Vivid Light">
                <cocoa string-value="vividLight"/>
            </enumerator>
            <enumerator name="linear light" code="Bmll" description="Linear Light">
                <cocoa string-value="linearLight"/>
            </enumerator>
            <enumerator name="pin light" code="Bmpl" description="Pin Light">
                <cocoa string-value="pinLight"/>
            </enumerator>
            <enumerator name="hard mix" code="Bmhx" description="Hard Mix">
                <cocoa string-value="hardMix"/>
            </enumerator>
            <enumerator name="difference" code="Bmdf" description="Difference">
                <cocoa string-value="difference"/>
            </enumerator>
            <enumerator name="exclusion" code="Bmex" description="Exclusion">
                <cocoa string-value="exclusion"/>
            </enumerator>
            <enumerator name="subtract" code="Bmsb" description="Subtract">
                <cocoa string-value="subtract"/>
            </enumerator>
            <enumerator name="divide" code="Bmdv" description="Divide">
                <cocoa string-value="divide"/>
            </enumerator>
            <enumerator name="hue blend mode" code="Bmhu" description="Hue">
                <cocoa string-value="hue"/>
            </enumerator>
            <enumerator name="saturation blend mode" code="Bmsa" description="Saturation">
                <cocoa string-value="saturation"/>
            </enumerator>
            <enumerator name="color blend mode" code="Bmcl" description="Color">
                <cocoa string-value="color"/>
            </enumerator>
            <enumerator name="luminosity" code="Bmlu" description="Luminosity">
                <cocoa string-value="luminosity"/>
            </enumerator>
