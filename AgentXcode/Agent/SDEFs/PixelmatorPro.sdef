            </enumerator>
            <enumerator name="linear burn" code="Bmlb" description="Linear Burn">
                <cocoa string-value="linearBurn"/>
            </enumerator>
            <enumerator name="darker color" code="Bmdc" description="Darken">
                <cocoa string-value="darkerColor"/>
            </enumerator>
            <enumerator name="lighten" code="Bmlg" description="Lighten">
                <cocoa string-value="lighten"/>
            </enumerator>
            <enumerator name="screen" code="fits" description="Screen">
                <cocoa string-value="screen"/>
            </enumerator>
            <enumerator name="color dodge" code="Bmcd" description="Color Dodge">
