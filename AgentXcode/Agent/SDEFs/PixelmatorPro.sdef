        <class name="color adjustments layer" code="PrAL" description="A color adjustments layer." inherits="layer" plural="color adjustments layers">
            <cocoa class="Pixelmator.ScriptingColorAdjustmentsLayer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Add a new color adjustments layer, store a reference to it in a variable, then set the brightness of the color adjustments of that layer to 50:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                            <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;margin-top:-6px;padding-left:10em;text-indent:-6em;">
                            <b>set</b> <span style="color:#408000;">adjustmentsLayer</span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>color adjustments layer</i> at</span> <b>the beginning of</b> <span style="color:blue;"><i>layers</i></span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>set the</b> <span style="color:#6C05D3;">brightness</span> <b>of the</b> <span style="color:blue;font-style:italic;">color adjustments</span> <b>of</b> <span style="color:#408000;">adjustmentsLayer</span> <b>to</b> 50
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="effects layer" code="PrEL" description="An effects layer." inherits="layer" plural="effects layers">
            <cocoa class="Pixelmator.ScriptingEffectsLayer"/>
