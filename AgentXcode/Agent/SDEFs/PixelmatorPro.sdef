        <enumeration name="resampling algorithm" code="Rsal" description="Resampling algorithms for scaling images.">
            <enumerator name="none" hidden="yes" code="Nors" description="None">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="bilinear" code="Blnr" description="Bilinear">
                <cocoa integer-value="2"/>
            </enumerator>
            <enumerator name="lanczos" code="Lncz" description="Lanczos">
                <cocoa integer-value="3"/>
            </enumerator>
            <enumerator name="nearest" code="Nrst" description="Nearest Neighbor">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="ml super resolution" code="Mlsr" description="Super Resolution">
                <cocoa integer-value="4"/>
            </enumerator>
        </enumeration>
        <enumeration name="selection mode" code="Slmd">
            <enumerator name="new selection" code="New " description="Create a new selection.">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="add selection" code="Add " description="Add to the existing selection.">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="subtract selection" code="Sbtr" description="Subtract from the existing selection.">
                <cocoa integer-value="2"/>
            </enumerator>
            <enumerator name="intersect selection" code="Intr" description="Intersect with the existing selection.">
                <cocoa integer-value="3"/>
            </enumerator>
        </enumeration>
        <enumeration name="scale mode" code="Slmd" description="Scaling method used when creating masks from images and replacing image layers.">
            <enumerator name="original" code="Orgn" description="Original scale.">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="stretch" code="Strt" description="Stretch to fill">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="scale to fill" code="Sfil" description="Scale to fill">
                <cocoa integer-value="2"/>
            </enumerator>
            <enumerator name="scale to fit" code="Sfit" description="Scale to fit">
                <cocoa integer-value="3"/>
            </enumerator>
        </enumeration>
        <enumeration name="mask mode" code="MsMd">
            <enumerator name="reveal all" code="Rval" description="A mask that is solid white and reveals all the contents of a layer.">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="hide all" code="Hdal" description="A mask that is solid black and hides all the contents of a layer.">
                <cocoa integer-value="1"/>
            </enumerator>
        </enumeration>
        <enumeration name="stroke position" code="Strp">
            <enumerator name="inside" code="Stin" description="Inside stroke">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="center" code="cent" description="Center stroke">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="outside" code="Stot" description="Outisde stroke">
                <cocoa integer-value="2"/>
            </enumerator>
        </enumeration>
        <enumeration name="stroke type" code="Sttp">
            <enumerator name="line" code="Line" description="Line stroke">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="dash" code="Dash" description="Dashed stroke">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="dot" code="Dot " description="Dotted stroke">
                <cocoa integer-value="2"/>
            </enumerator>
        </enumeration>
        <enumeration name="anchor" code="Anch" description="-">
            <enumerator name="top left" code="Tplf">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="top center" code="Tpcn">
                <cocoa integer-value="2"/>
            </enumerator>
            <enumerator name="top right" code="Tprg">
                <cocoa integer-value="3"/>
            </enumerator>
            <enumerator name="middle left" code="Mdlf">
                <cocoa integer-value="4"/>
            </enumerator>
            <enumerator name="middle center" code="Cntr">
                <cocoa integer-value="5"/>
            </enumerator>
            <enumerator name="middle right" code="Mdrg">
                <cocoa integer-value="6"/>
            </enumerator>
            <enumerator name="bottom left" code="Btlf">
                <cocoa integer-value="7"/>
            </enumerator>
            <enumerator name="bottom center" code="Btcn">
                <cocoa integer-value="8"/>
            </enumerator>
            <enumerator name="bottom right" code="Btrg">
                <cocoa integer-value="9"/>
            </enumerator>
        </enumeration>
        <enumeration name="trim mode" code="Trmd" description="-">
            <enumerator name="transparency" code="Trtr">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="top left color" code="Trtl">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="bottom right color" code="Trbr">
                <cocoa integer-value="2"/>
            </enumerator>
        </enumeration>
        <enumeration name="color profile mode" code="Ccpm" description="-">
            <enumerator name="assign" code="Cpas">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="match" code="Cpmt">
                <cocoa integer-value="1"/>
            </enumerator>
        </enumeration>
        <record-type name="face feature information" code="PrFI" description="The size and position of a face detected in the document. For convenience, three lists are returned: the position, size, and bounds, which is a combination of the first two properties.">
            <property name="bounds" code="pbnd" description="The frame of the face area as 4 integers in a list. The first two represent the position of the top left corner of the area and the second two represent its width and height.">
                <cocoa key="Bounds" />
                <type type="integer" list="yes" />
            </property>
            <property name="position" code="posn" type="point" description="The position of the top left corner of the face area.">
                <cocoa key="Position" />
            </property>
            <property name="size" code="ptsz" description="The width and height of the face area.">
                <cocoa key="Size" />
                <type type="integer" list="yes" />
            </property>
        </record-type>
        <record-type name="QR code feature information" code="PrQR" description="The size and position of a QR code detected in the document. Along with the text contained in the QR code, three lists are returned for convenience: the position, size, and bounds, which is a combination of the first two properties.">
            <property name="bounds" code="pbnd" description="The frame of the QR code area as 4 integers in a list. The first two represent the position of the top left corner of the area and the second two represent its width and height.">
                <cocoa key="Bounds" />
                <type type="integer" list="yes" />
            </property>
            <property name="position" code="posn" type="point" description="The position of the top left corner of the QR code area.">
                <cocoa key="Position" />
            </property>
            <property name="size" code="ptsz" description="The width and height of the QR code area.">
                <cocoa key="Size" />
                <type type="integer" list="yes" />
            </property>
            <property name="message" code="mesS" type="text" description="The message contained in the QR code.">
                <cocoa key="Message" />
            </property>
        </record-type>
        <enumeration name="DiUr" code="DiUr">
            <enumerator name="none" code="DNne">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="high" code="e107">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="two" code="Two ">
                <cocoa integer-value="2"/>
            </enumerator>
            <enumerator name="three" code="e103">
                <cocoa integer-value="3"/>
            </enumerator>
            <enumerator name="four" code="Four">
                <cocoa integer-value="4"/>
            </enumerator>
            <enumerator name="normal" code="Nrml">
                <cocoa integer-value="5"/>
            </enumerator>
            <enumerator name="six" code="e105">
                <cocoa integer-value="6"/>
            </enumerator>
            <enumerator name="seven" code="e106">
                <cocoa integer-value="7"/>
            </enumerator>
            <enumerator name="low" code="e101">
                <cocoa integer-value="8"/>
            </enumerator>
        </enumeration>
        <enumeration name="DiCp" code="DiCp">
            <enumerator name="unmarked" code="Cp03">
                <cocoa integer-value="-1"/>
            </enumerator>
            <enumerator name="copyrighted work" code="Cp01">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="public domain" code="Cp02">
                <cocoa integer-value="0"/>
            </enumerator>
        </enumeration>
        <enumeration name="application appearance" code="Aapr">
            <enumerator name="auto" code="Auta" description="Adjust Pixelmator Pro appearance automatically to match system appearance.">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="dark" code="Adrk" description="Dark appearace.">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="light" code="Algh" description="Light appearance.">
                <cocoa integer-value="2"/>
            </enumerator>
        </enumeration>
        <enumeration name="image opening workflow" code="Aiow">
            <enumerator name="open in original format" code="Aioo" description="Open non-Pixelmator Pro files (JPEG, PNG, etc.) in their original format whenever possible.">
                <cocoa string-value="openInOriginalFormat"/>
            </enumerator>
            <enumerator name="import as pixelmator pro" code="Aioi" description="Create a new Pixelmator Pro file for every image opened in a non-native format.">
                <cocoa string-value="openInPixelmatorProFormat"/>
            </enumerator>
        </enumeration>
        <enumeration name="sidecar location" code="Asdl" description="The location that sidecar files are currently being saved in.">
            <enumerator name="icloud drive" code="Asdi" description="A folder in the Pixelmator Pro folder in iCloud Drive.">
                <cocoa string-value="iCloud"/>
            </enumerator>
            <enumerator name="pictures folder" code="Asdp" description="A folder in the Pictures folder.">
                <cocoa string-value="local"/>
            </enumerator>
        </enumeration>
        
        <command name="delete" code="coredelo" description="Delete an object.">
            <cocoa class="Pixelmator.DeleteCommand" />
            <access-group identifier="*" />
            <direct-parameter type="specifier" description="The objcect(s) to delete." />
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Delete the third layer in a document:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>delete</b></span> <span style="color:blue;font-style:italic;">layer</span> 3</p>
                        </div>
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Delete the every hidden layer in a document:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>delete</b></span> (<b>every</b> <span style="color:blue;font-style:italic;">layer</span> <b>whose</b> <span style="color:#6C05D3;">visible</span> <b>is</b> <span style="color:#6C05D3;font-style:italic;">false</span>)</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="make" code="corecrel" description="Create a new object.">
            <cocoa class="Pixelmator.CreateCommand" />
            <access-group identifier="*" />
            <parameter name="new" code="kocl" type="type" description="The class of the new object.">
                <cocoa key="ObjectClass" />
            </parameter>
            <parameter name="at" code="insh" type="location specifier" optional="yes" description="The location at which to insert the object.">
                <cocoa key="Location" />
            </parameter>
            <parameter name="with data" code="data" type="any" optional="yes" description="The initial contents of the object.">
                <cocoa key="ObjectData" />
            </parameter>
            <parameter name="with properties" code="prdt" type="record" optional="yes" description="The initial values for properties of the object.">
                <cocoa key="KeyDictionary" />
            </parameter>
            <result type="specifier" description="The new object." />
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create an empty image layer at the beginning of the layer list:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <b>tell the front</b> <span style="color:blue;"><i>document</i></span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>image layer</i> at</span> <b>the beginning of</b> <span style="color:blue;font-style:italic;">layers</span></p>
                        </div>
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a new image layer from a file on the desktop named New.png and set the new layer's preserve transparency to true and constrain proportions to false:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>make</b></span> <span style="color:blue;">new</span> <span style="color:blue;font-style:italic;">image layer</span> <span style="color:blue;">with properties</span> {<span style="color:blue;font-style:italic;">file</span>:((<span style="color:#0016B0;"><b>path to</b></span> <span style="color:#4415B0;font-style:italic;">desktop</span> <span style="color:#0016B0;">as</span> <span style="color:blue;font-style:italic;">text</span>) & "New.png"), <span style="color:#6C05D3;">preserve transparency</span>:<span style="color:#6C05D3;font-style:italic;">true</span>, <span style="color:#6C05D3;">constrain proportions</span>:<span style="color:#6C05D3;font-style:italic;">false</span>}</p>
                        </div>
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a new polygon shape layer with 6 sides, whose top left corner is at 100 pixels down and 200 pixels across with a height of 500 by 500 pixels, insert it after the fourth layer, and store the reference to it in a variable:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to set</b> <span style="color:#408000;">theHexagon</span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>polygon shape layer</i> at</span> <b>after</b> <span style="color:blue;font-style:italic;">layer</span> 4 <span style="color:blue;">with properties</span> {<span style="color:#6C05D3;">position</span>:{100, 200}, <span style="color:#6C05D3;">width</span>:500, <span style="color:#6C05D3;">height</span>:500, <span style="color:#6C05D3;">sides</span>:6}</p>
                        </div>
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a new text layer, change its text to "Hello World" and store the reference to the layer in a variable, then set the color of the text to black, the font to Helvetica, and the size too 100 pixels:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                            <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;margin-top:-6px;padding-left:10em;text-indent:-6em;">
                            <b>set</b> <span style="color:#408000;">myText</span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>text layer</i> at</span> <b>the beginning of</b> <span style="color:blue;"><i>layers</i> with properties</span> {<span style="color:#6C05D3;">text content</span>:"Hello World"}
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>tell the</b> <span style="color:#6C05D3;">text content</span> <b>of</b> <span style="color:#408000;">myText</span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <b>set its</b> <span style="color:blue;font-style:italic;">color</span> <b>to</b> {0, 0, 0}
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">font</span> <b>to</b> "Helvetica"
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">size</span> <b>to</b> 100
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="duplicate" code="coreclon" description="Make a copy of an object.">
            <cocoa class="Pixelmator.DuplicateCommand" />
            <access-group identifier="*" />
            <direct-parameter type="specifier" description="The object(s) to copy." />
            <parameter name="to" code="insh" type="location specifier" description="The location for the new copy or copies." optional="yes">
                <cocoa key="ToLocation" />
            </parameter>
            <parameter name="with properties" code="prdt" type="record" description="Properties to set in the new copy or copies right away." optional="yes">
                <cocoa key="WithProperties" />
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Duplicate the first layer of the document and put the copy at the end of layers:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <b>tell the front</b> <span style="color:blue;"><i>document</i></span> <b>to</b> <span style="color:blue;"><b>duplicate</b></span> <b>the first</b> <span style="color:blue;"><i>layer</i> to</span> <b>the end of</b> <span style="color:blue;font-style:italic">layers</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        
        <!-- File Menu -->
        
        <command name="save as new document" code="PProsvas" hidden="yes" description="Save a document to a different file.">
            <direct-parameter type="document" description="The document to save." />
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="in" code="insh" type="file" description="The destination file.">
                <cocoa key="Destination" />
            </parameter>
            <parameter name="as" code="savf" type="saveable file format" description="The format to use.">
                <cocoa key="SaveFormat" />
            </parameter>
            <parameter name="quality" code="Sqlt" type="integer" optional="yes" description="The export quality to use with lossy compressed formats.">
                <cocoa key="SaveAsQuality" />
            </parameter>
            <parameter name="sidecar" code="Ssdr" type="boolean" optional="yes" description="Optionally create a sidecar file linked to the original image – only supported for non-native file types.">
                <cocoa key="SavingSidecarFile" />
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Export the current document in JPEG format to an image called MyImage.jpg located on the desktop:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <span style="color:blue;"><b>export</b></span> <b>the front</b> <span style="color:blue;"><i>document</i> to <i>file</i></span> ((<span style="color:#0016B0;"><b>path to</b></span> <span style="color:#4415B0;font-style:italic;">desktop</span> <span style="color:#0016B0;">as</span> <span style="color:blue;font-style:italic;">text</span>) & "MyImage.jpg") <span style="color:blue;">as</span> <span style="color:#6C05D3;font-style:italic;">JPEG</span> <span style="color:blue;">with properties</span> {<span style="color:#6C05D3;">compression factor</span>:85}</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="export" code="PProexpo" description="Export an image to another file.">
            <direct-parameter type="document" description="The image to export" />
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="to" code="insh" type="file" description="the destination file">
                <cocoa key="Destination" />
            </parameter>
            <parameter name="as" code="fltp" type="export format" description="The format to use.">
                <cocoa key="ExportFormat" />
            </parameter>
            <parameter name="with properties" code="prdt" type="export options" optional="yes" description="Optional export settings.">
                <cocoa key="ExportProperties" />
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Export the current document in JPEG format to an image called MyImage.jpg located on the desktop:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <span style="color:blue;"><b>export</b></span> <b>the front</b> <span style="color:blue;"><i>document</i> to <i>file</i></span> ((<span style="color:#0016B0;"><b>path to</b></span> <span style="color:#4415B0;font-style:italic;">desktop</span> <span style="color:#0016B0;">as</span> <span style="color:blue;font-style:italic;">text</span>) & "MyImage.jpg") <span style="color:blue;">as</span> <span style="color:#6C05D3;font-style:italic;">JPEG</span> <span style="color:blue;">with properties</span> {<span style="color:#6C05D3;">compression factor</span>:85}</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="export optimized" code="PProexop" description="Export an image to another file."  hidden="yes">
            <direct-parameter type="document" description="The image to export" />
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="to" code="insh" type="file" description="the destination file">
                <cocoa key="Destination" />
            </parameter>
        </command>
        <command name="export for web" code="PProexwb" description="Export an image to another file, optimizing it for the web.">
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <direct-parameter type="document" description="The image to export" />
            <parameter name="to" code="insh" type="file" description="the destination file">
                <cocoa key="Destination" />
            </parameter>
            <parameter name="as" code="fltp" type="export for web format" description="The format to use for export for web.">
                <cocoa key="ExportForWebFormat" />
            </parameter>
            <parameter name="with properties" code="prdt" type="export for web options" optional="yes" description="Optional export settings.">
                <cocoa key="ExportForWebProperties" />
            </parameter>
        </command>
        
        <!-- Edit Menu -->
        
        <command name="undo" code="PProundo" description="Undo changes.">
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <direct-parameter type="document"/>
        </command>
        <command name="redo" code="PProredo" description="Redo changes.">
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <direct-parameter type="document"/>
        </command>
        <command name="cut" code="PProcut " description="Cut the selected layer or image area, copying it to the clipboard.">
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <direct-parameter type="document"/>
        </command>
        <command name="copy" code="misccopy" description="Copy the selected layer or image area to the clipboard.">
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <direct-parameter type="document"/>
        </command>
        <command name="paste" code="PPropast" description="Paste the contents of the clipboard into the document.">
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <direct-parameter type="document"/>
        </command>
        
        <command name="select all" code="PProsall" description="Draw a selection around the entire image.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="deselect" code="PProdslt" description="Deselect any active selections.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="reselect" code="PProrslt" description="Reselect the most recent selection.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="invert selection" code="PProsinv" description="Invert a selection, changing the unselected areas into selected and vice versa.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="load selection" code="PProslld" description="Load the outline of a layer as a selection.">
            <direct-parameter type="layer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="mode" code="Slmd" description="Optionally combine this selection with the currently active selection." type="selection mode" optional="yes">
                <cocoa key="SelectionMode"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Load the outline of the first layer of the active document as a selection and add it to the existing selection:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><span style="color:blue;"><b>load selection</b></span> <b>of the first</b> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span> <span style="color:blue;">mode</span> <span style="color:#6C05D3;font-style:italic;">add selection</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="select subject" code="PProSlSb" description="Automatically select the main subject of a document or layer.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="smart refine" code="PTsm" description="Whether the selection should be additionally refined using the Smart Refine feature. True by default." type="boolean" optional="yes">
                <cocoa key="SmartRefine"/>
            </parameter>
        </command>
        <command name="refine selection" code="PProsref" description="Refine a selection, adjusting its roundness, softness, and size.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="roundness" code="Rnds" description="The roundness of a selection, from 0 (none) to 100 (maximum roundness)." type="integer" optional="yes">
                <cocoa key="RefineRoundness"/>
            </parameter>
            <parameter name="softness" code="Sftn" description="The softness of a selection, from 0 (none) to 100 (maximum softness)." type="integer" optional="yes">
                <cocoa key="RefineSoftness"/>
            </parameter>
            <parameter name="expand" code="Expd" description="Expand or contract a selection, from -100 to 100." type="integer" optional="yes">
                <cocoa key="RefineExpand"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Refine a selection to slightly soften and epxand it:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>refine selection</b></span> <span style="color:blue;">softness</span> 10.0 <span style="color:blue;">expand</span> 2.0</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="smart refine selection" code="PProMLrf" description="Automatically refine the edges of a selection.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Automatically refine the currently active selection:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>smart refine selection</b></span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="select color range" code="PProsclr" description="Select all areas of a specified color. This command can be executed on the document (in which case every layer is sampled) or on a layer, in which case the selection is created based on the layer's content.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="color" code="colr" description="The color of the areas that should be selected.">
                <type type="integer" list="yes"/>
                <cocoa key="Color" />
            </parameter>
            <parameter name="range" code="PTra" description="The range of the colors that should be selected. With a range of 1, only areas that are exactly of the specified color will be selected. As the range is increased, increasingly more similarly-colored areas will be selected." type="integer" optional="yes">
                <cocoa key="Range"/>
            </parameter>
            <parameter name="mode" code="Slmd" description="Optionally combine this selection with the currently active selection." type="selection mode" optional="yes">
                <cocoa key="SelectionMode"/>
            </parameter>
            <parameter name="smooth edges" code="PTse" description="Whether the edges of the selection should be smoothed." type="boolean" optional="yes">
                <cocoa key="SmoothEdges"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Select all areas in the image with the specified color (a shade of yellow) and range of 10:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>select color range</b></span> <span style="color:#6C05D3;">color</span> {58650, 52020, 22440} <span style="color:#6C05D3;">range</span> 10</p>
                        </div>

                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a selection based on the color of the contents of the first layer – the specified color is a shade of yellow and the range is 10:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document's</span> <b>first</b> <span style="color:blue;font-style:italic;">layer</span> <b>to</b> <span style="color:blue;"><b>select color range</b></span> <span style="color:#6C05D3;">color</span> {58650, 52020, 22440} <span style="color:#6C05D3;">range</span> 10</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="draw selection" code="PProdrsl" description="Draw a rectangular selection.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="bounds" code="pbnd" description="The bounds of the selection as 4 integers in a list. The first two represent the position of the top left corner of the selection and the second two represent its width and height.">
                <type type="integer" list="yes"/>
                <cocoa key="Bounds"/>
            </parameter>
            <parameter name="mode" code="Slmd" description="Optionally combine this selection with the currently active selection." type="selection mode" optional="yes">
                <cocoa key="SelectionMode"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Draw a rectangular selection whose top left corner is at 40 pixels down and 40 pixels across with a size of 1000 by 1000 pixels:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>draw selection</b></span> <span style="color:#6C05D3;">bounds</span> {40,40,1000,1000}</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="draw elliptical selection" code="PProdrel" description="Draw an elliptical selection.">
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <!-- Stopped working in macOS 12.1 FB9805038
            <synonym name="draw oval selection"/>
            -->
            <direct-parameter type="document"/>
            <parameter name="bounds" code="pbnd" description="The bounds of the selection as 4 integers in a list. The first two represent the position of the top left corner of the selection and the second two represent its width and height.">
                <type type="integer" list="yes"/>
                <cocoa key="Bounds"/>
            </parameter>
            <parameter name="mode" code="Slmd" description="Optionally combine this selection with the currently active selection." type="selection mode" optional="yes">
                <cocoa key="SelectionMode"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Draw an elliptical selection whose top left corner is at 40 pixels down and 40 pixels across with a size of 1000 by 1000 pixels and subtract it from an active selection:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>draw elliptical selection</b></span> <span style="color:#6C05D3;">bounds</span> {40,40,1000,1000} <span style="color:blue;">mode</span> <span style="color:#6C05D3;font-style:italic;">subtract selection</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="convert selection into shape" code="PProcnss" description="Convert a selection into a shape.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <result type="shape layer"/>
        </command>
        <command name="fill" code="PProfill" description="Fill the current layer or selected area with a color.">
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <direct-parameter type="document"/>
            <parameter name="with color" code="WtCl" description="A color, expressed as a 16-bit RGBa value consisting of a list of three color values from 0 to 65535 and an optional alpha (transparency) value from 0 to 65535. For example: Blue = {0, 0, 65535} while blue with 50% opacity = {0, 0, 65535, 32768}.">
                <type type="integer" list="yes"/>
                <cocoa key="Color"/>
            </parameter>
            <parameter name="preserve transparency" code="PrTS" description="Preserve the transparency of the layer being filled by filling its opaque areas only." type="boolean" optional="yes">
                <cocoa key="PreserveTransparency"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Fill the (topmost) layer named Square with the color blue while preserving its transparency (i.e. filling only opaque areas):</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>fill</b> layer</span> <span style="color:#6C05D3;font-style:italic;">named</span> "Square" <span style="color:blue;">with color</span> {0,0,65535} <b>with</b> <span style="color:#6C05D3;font-style:italic;">preserve transparency</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="clear" code="PProcler" description="Delete the currently selected areas of a layer.">
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <direct-parameter type="document"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Delete the currently selected area of the current layer:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>clear</b></span> <b>the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        
        <command name="replace" code="PProrptx" description="Replace text in the text layers of a document.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="text" code="Fntx" type="text" description="The text to be replaced.">
                <cocoa key="FindText"/>
            </parameter>
            <parameter name="with" code="with" type="text" description="The replacement text.">
                <cocoa key="ReplaceText"/>
            </parameter>
            <parameter name="with properties" code="prdt" type="replace text properties" optional="yes" description="Optional properties to customize text replacement.">
                <cocoa key="ReplaceTextProperties"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Replace all instances of "Bob" with "Jim" in the front document (only replacing whole words and matching case):</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                            <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;margin-top:-6px;padding-left:10em;text-indent:-6em;">
                            <span style="color:blue;"><b>replace</b> text</span> "Bob" <span style="color:blue;">with</span> "Jim" <span style="color:blue;">with properties</span> {<span style="color:#6C05D3;">match words</span>:<span style="color:#6C05D3;font-style:italic;">true</span>, <span style="color:#6C05D3;">case sensitive</span>:<span style="color:#6C05D3;font-style:italic;">true</span>}
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        
        <command name="pick color" code="PProPcCl" description="Pick a color at specific coordinates in a document.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="at" code="insh" description="The location at which to pick the color." type="point">
                <cocoa key="Point"/>
            </parameter>
            <result description="The color expressed as a list of 4 integers {R, G, B, and alpha}.">
                <type type="integer" list="yes"/>
            </result>
        </command>
        
        <!-- Insert Menu -->
        
        <command name="make image" code="PProInIm" hidden="yes">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="from" code="Flnm" type="file" description="-">
                <cocoa key="URL"/>
            </parameter>
            <result type="image layer"/>
        </command>
        <command name="make rectangle" code="PProRect" hidden="yes">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="width" code="widD" description="-" type="integer">
                <cocoa key="ShapeSizeWidth"/>
            </parameter>
            <parameter name="height" code="Hgth" type="integer">
                <cocoa key="ShapeSizeHeight"/>
            </parameter>
            <parameter name="color" code="colr" optional="yes">
                <type type="integer" list="yes"/>
                <cocoa key="Color" />
            </parameter>
            <result type="shape layer"/>
        </command>
        <command name="make rounded rectangle" code="PProRrct" hidden="yes">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="width" code="widD" description="-" type="integer">
                <cocoa key="ShapeSizeWidth"/>
            </parameter>
            <parameter name="height" code="Hgth" type="integer">
                <cocoa key="ShapeSizeHeight"/>
            </parameter>
            <parameter name="corner radius" code="Crrd" type="real" optional="yes">
                <cocoa key="ShapeCornerRadius"/>
            </parameter>
            <parameter name="color" code="colr" optional="yes">
                <type type="integer" list="yes"/>
                <cocoa key="Color" />
            </parameter>
            <result type="shape layer"/>
        </command>
        <command name="make group" code="PPromkgr" hidden="yes">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="from" code="Flnm" optional="yes">
                <type type="layer" list="yes" />
                <cocoa key="Layers"/>
            </parameter>
            <result type="group layer"/>
        </command>
        
        <!-- Image Menu -->
        
        <command name="crop" code="PProcrop" description="Crop a document.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="bounds" code="pbnd" description="The frame of the crop area as 4 integers in a list. The first two represent the position of the top left corner of the area and the second two represent its width and height.">
                <type type="integer" list="yes"/>
                <cocoa key="Bounds"/>
            </parameter>
            <parameter name="delete mode" code="Crdl" description="Delete cropped pixels instead of hiding them." type="boolean" optional="yes">
                <cocoa key="CropDeleteMode"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Crop the current document, positioning the top left corner of the crop area at 100 pixels down and 100 pixels across and cropping to a size of 1920 pixels by 1080 pixels:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>crop</b></span> <span style="color:#6C05D3;">bounds</span> {100, 100, 1920, 1080} <b>with</b> <span style="color:blue;">delete mode</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="resize image" code="PProimsz" description="Change the size of an image.">
            <!-- Stopped working in macOS 12.1 FB9805038
            <synonym name="adjust size"/>
            <synonym name="image size"/>
            -->
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="width" code="widD" description="Set the new width (in pixels) of the image." type="integer" optional="yes">
                <cocoa key="ImageSizeWidth"/>
            </parameter>
            <parameter name="height" code="Hgth" description="Set the new height (in pixels) of the image." type="integer" optional="yes">
                <cocoa key="ImageSizeHeight"/>
            </parameter>
            <parameter name="resolution" code="Resl" description="Set the new resolution (in pixels per inch) of the image." type="real" optional="yes">
                <cocoa key="ImageSizeResolution"/>
            </parameter>
            <parameter name="algorithm" code="Rsal" description="Choose the algorithm to use when resampling the image." type="resampling algorithm" optional="yes">
                <cocoa key="ImageSizeAlgorithm"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Change the size of the image to 1920 pixels by 1080 pixels with a resolution of 72 pixels per inch and resample using the bilinear algorithm:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>resize image</b></span> <span style="color:#6C05D3;">width</span> 1920 <span style="color:#6C05D3;">height</span> 1080 <span style="color:blue;">resolution</span> 72 <span style="color:blue;">algorithm</span> <span style="color:#6C05D3;font-style:italic;">bilinear</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="resize canvas" code="PProcnsz" description="Change the size of the image canvas.">
            <!-- Stopped working in macOS 12.1 FB9805038
            <synonym name="adjust canvas"/>
            <synonym name="canvas size"/>
            -->
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <direct-parameter type="document"/>
            <parameter name="width" code="widD" description="Set the new width (in pixels) of the image." type="integer" optional="yes">
                <cocoa key="CanvasSizeWidth"/>
            </parameter>
            <parameter name="height" code="Hgth" description="Set the new height (in pixels) of the image." type="integer" optional="yes">
                <cocoa key="CanvasSizeHeight"/>
            </parameter>
            <parameter name="relative" code="Relt" description="When relative is true, the width and height are added to or subtracted from the current size of the canvas." type="boolean" optional="yes">
                <cocoa key="CanvasSizeRelative"/>
            </parameter>
            <parameter name="anchor position" code="anch" description="The position of the existing image content on the new canvas." type="anchor" optional="yes">
                <cocoa key="CanvasSizeAnchor"/>
            </parameter>
             <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Change the size of the canvas to 1920 pixels by 1080 pixels and place existing content in the center of the new image:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>resize canvas</b></span> <span style="color:#6C05D3;">width</span> 1920 <span style="color:#6C05D3;">height</span> 1080 <span style="color:blue;">anchor position</span> <span style="color:#6C05D3;font-style:italic;">middle center</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="rotate 180" code="PPrort18" description="Rotate the entire image by 180 degrees.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="rotate right" code="PPrortrg" description="Rotate the entire image by 90 degrees clockwise.">
            <synonym name="rotate -90"/>
            <synonym name="rotate 270"/>
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="rotate left" code="PPrortlf" description="Rotate the entire image by 90 degrees counterclockwise.">
            <synonym name="rotate 90"/>
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="flip horizontally" code="PProflhr" description="Flip the entire image horizontally.">
            <synonym name="flip horizontal"/>
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="flip vertically" code="PProflvt" description="Flip the entire image vertically.">
            <synonym name="flip vertical"/>
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="super resolution" code="PProMLSR" description="Increase the resolution of the image by 300% using the Super Resolution algorithm.">
            <synonym name="enhance resolution"/>
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="trim canvas" code="PProtrcn" description="Trim away colored or transparent pixels at the edges of the image.">
            <direct-parameter type="document"/>
            <parameter name="mode" code="trmd" description="Trim away transparent pixels or pixels that are the same color as the top left or bottom right pixel." type="trim mode" optional="yes">
                <cocoa key="TrimMode"/>
            </parameter>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="reveal canvas" code="PProrvcn" description="Expand the canvas to reveal any image areas beyond the canvas edges.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="change color profile" code="PProclpr" description="Change the color profile of the image.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="to" code="insh" description="The name of the color profile." type="text">
                <cocoa key="ColorSpaceName"/>
            </parameter>
            <parameter name="mode" code="Cpmd" description="Assign the new profile (keep the same color values), or match it (change the color values so colors keep their look in the new profile)." type="color profile mode" optional="yes">
                <cocoa key="ColorSpaceMode"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Assign the Display P3 color profile to the current document:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;">
                            <span style="color:blue;"><b>change color profile</b></span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span> <span style="color:blue;">to</span> "Display P3" <span style="color:blue;">mode</span> <span style="color:#6C05D3;font-style:italic;">assign</span>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="change color depth" code="PProcldp" description="DEPRECATED. Use bits per channel property." hidden="yes">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="to" code="insh" description="-" type="integer">
                <cocoa key="BitsPerChannel"/>
            </parameter>
        </command>
        <command name="detect face" code="PProDeFC" description="Find the location of a face in a document.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info"/>
            <result type="face feature information"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Find the location of a face in the document and store its properties in a variable:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <b>set</b> <span style="color:#408000;">faceInformation</span> <b>to</b> <span style="color:blue;"><b>detect face</b></span> <b>of the front</b></span> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="detect QR code" code="PProDeQR" description="Find the location of a QR code in a document.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info"/>
            <result type="QR code feature information"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Find the location of a QR code in the document and store its properties in a variable:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <b>set</b> <span style="color:#408000;">qrInformation</span> <b>to</b> <span style="color:blue;"><b>detect QR code</b></span> <b>of the front</b></span> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <!-- Format Menu -->
        
        <command name="enhance" code="PProMLEn" description="Automatically enhance the colors of a layer in the image using the ML Enhance algorithm.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Automatically enhance the colors of the second layer in the current document:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>enhance</b></span> <b>the second</b></span> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="match colors" code="PProMLmc" description="Automatically edit the colors of an image to copy the look and feel of another image using the Match Colors algorithm.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="to" code="insh" type="file" description="The image whose style should be copied.">
                <cocoa key="URL"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Copy the style of an image named "Colors.png" located on the desktop and apply it to the first layer in the current document:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>match colors</b></span> <b>of the first</b> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span> <span style="color:blue;">to</span> ((<span style="color:#0016B0;"><b>path to</b></span> <span style="color:#4415B0;font-style:italic;">desktop</span> <span style="color:#0016B0;">as</span> <span style="color:blue;font-style:italic;">text</span>) & "Colors.png")</p>
                        </div>

                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Copy the style of the image picked using a Finder dialog and apply that style to the currently selected layer:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;"><span style="color:blue;"><b>match colors</b></span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span> <span style="color:blue;">to</span> (<span style="color:#0016B0;"><b>choose file</b> with prompt</span> "Select an image to copy its style:" <span style="color:#0016B0;">of type</span> {"public.image"})</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="auto white balance" code="PProMLWB" description="Automatically adjust the white balance of a layer.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Automatically white balance the first layer in the current document:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>auto white balance</b></span> <b>the first</b></span> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="auto light" code="PProMLLG" description="Automaticaly edit the colors of the image using the Lightness adjustment to improve its lighting.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
             <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Automatically improve the lighting of the currently selected layer using the Lightness adjustment:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>auto light</b></span> <b>the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="auto color balance" code="PProMLCB" description="Automatically enhance the colors of the image using the Color Balance adjustment.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Automatically enhance the colors of the currently selected layer using the Color Balance adjustment:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>auto color balance</b></span> <b>the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="auto hue and saturation" code="PProMLHS" description="Automatically enhance the colors of the image using the Hue &amp; Saturation adjustment.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Automatically enhance the colors of the currently selected layer using the Hue & Saturation adjustment:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>auto hue and saturation</b></span> <b>the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="auto levels contrast" code="PProLvCt" description="-" hidden="yes">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="auto levels color" code="PProLvCl" description="-" hidden="yes">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="auto curves contrast" code="PProCrCt" description="-" hidden="yes">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="auto curves color" code="PProCrCl" description="-" hidden="yes">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="denoise" code="PProMLDN" description="Automatically remove noise from an image using ML Denoise.">
            <direct-parameter type="document"/>
            <parameter name="intensity" code="Dnam" description="The intensity of the noise removal algorithm. Supported values are from 0 to 100, higher values result in more noise being removed." type="integer" optional="yes">
                <cocoa key="DenoiseIntensity"/>
            </parameter>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Automatically remove camera noise from the currently selected layer:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>denoise</b></span> <b>the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="deband" code="PProMLDB">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="mask" code="PProadms" description="Add a layer mask to a layer.">
            <direct-parameter type="layer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="from" code="Flnm" description="Create the layer mask using an image." type="file" optional="yes">
                <cocoa key="URL"/>
            </parameter>
            <parameter name="scale mode" code="Scmd" description="When creating a layer mask from an image, choose how to scale the mask image to the size of the mask." type="scale mode" optional="yes">
                <cocoa key="ScaleMode"/>
            </parameter>
            <parameter name="mask mode" code="Msmd" description="When creating a regular layer mask (not from an image), choose whether the mask should reveal or hide the contents of the layer." type="mask mode" optional="yes">
                <cocoa key="MaskMode"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Add a layer mask to the currently selected layer that hides all the contents of the layer:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>mask</b></span> <b>the front</b> <span style="color:blue;font-style:italic;">document's</span> <span style="color:#6C05D3;font-style:italic;">current layer</span> <span style="color:blue;">mask mode</span> <span style="color:#6C05D3;font-style:italic;">hide all</span></p>
                        </div>

                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Add a layer mask to the bottom layer of the document from an image called Mask.png located on the desktop:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>mask</b></span> <b>the front</b> <span style="color:blue;font-style:italic;">document's</span> <b>last</b> <span style="color:blue;font-style:italic;">layer</span> <span style="color:blue;">from</span> ((<span style="color:#0016B0;"><b>path to</b></span> <span style="color:#4415B0;font-style:italic;">desktop</span> <span style="color:#0016B0;">as</span> <span style="color:blue;font-style:italic;">text</span>) & "Mask.png")</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="unmask" code="PPrormms" description="Remove a layer mask from a layer.">
            <direct-parameter type="layer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Remove a layer mask from the currently selected layer:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>unmask</b></span> <b>the front</b> <span style="color:blue;font-style:italic;">document's</span> <span style="color:#6C05D3;font-style:italic;">current layer</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="replace image" code="PProadri" description="Replace an image layer with another, while preserving its adjustments, effects, and layer styles.">
            <direct-parameter type="image layer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="with" code="with" description="The replacement image." type="file">
                <cocoa key="URL"/>
            </parameter>
            <parameter name="scale mode" code="Scmd" description="The way the new image should be scaled to the size of the old image." type="scale mode" optional="yes">
                <cocoa key="ScaleMode"/>
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Replace the first layer of the current document with an image called New.png located on the desktop:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>replace image</b></span> <b>the first</b> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span> <span style="color:blue;">with</span> ((<span style="color:#0016B0;"><b>path to</b></span> <span style="color:#4415B0;font-style:italic;">desktop</span> <span style="color:#0016B0;">as</span> <span style="color:blue;font-style:italic;">text</span>) & "New.png")</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="remove background" code="PProRmBg" description="Automatically remove the background from an image or layer.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
             <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Automatically remove the background from the first layer in the current document:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>remove background</b></span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="invert colors" code="PProInCl" description="Invert the colors of an image layer.">
            <direct-parameter type="image layer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="decontaminate colors" code="PProDeCl" description="Remove colored tinting (a.k.a. fringing) from the edges of an image layer.">
            <direct-parameter type="image layer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="convert into shape" code="PProcnsh" description="Convert a text layer into a shape.">
            <direct-parameter type="text layer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="convert into pixels" code="PProcnpx" description="Convert a layer into pixels. This can be used to both convert text and shapes into pixels or flatten all nondestructive edits.">
            <direct-parameter type="layer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
        </command>
        <command name="apply color adjustments preset" code="PProapad" description="Apply a color adjustment preset to a layer.">
            <direct-parameter type="layer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="name" code="pnam" type="text" description="The name of the color adjustment preset to apply.">
                <cocoa key="Name"/>
            </parameter>
        </command>
        <command name="apply effects preset" code="PProapef" description="Apply an effect preset to a layer.">
            <direct-parameter type="layer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="name" code="pnam" type="text" description="The name of the effect preset to apply.">
                <cocoa key="Name"/>
            </parameter>
        </command>
        <command name="flatten" code="PProflad" description="Flatten the color adjustments of a layer.">
            <direct-parameter type="color adjustments"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Flatten the color adjustments of a layer named "Bubbles":</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>flatten</b></span> <b>the</b> <span style="color:blue;font-style:italic;">color adjustments</span> <b>of the</b> <span style="color:blue;font-style:italic;">layer</span> <span style="color:#6C05D3;font-style:italic;">named</span> "Bubbles"</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="reset" code="PProrsad" description="Reset the color adjustments of a layer.">
            <direct-parameter type="color adjustments"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Reset the color adjustments of a layer named "Bubbles":</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>reset</b></span> <b>the</b> <span style="color:blue;font-style:italic;">color adjustments</span> <b>of the</b> <span style="color:blue;font-style:italic;">layer</span> <span style="color:#6C05D3;font-style:italic;">named</span> "Bubbles"</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="export as lut" code="PProexlu" description="Export the color adjustments of a layer to a 3D LUT file.">
            <direct-parameter type="color adjustments" />
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="to" code="insh" type="file" description="the destination file">
                <cocoa key="Destination" />
            </parameter>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Export the color adjustments of the first layer of the from document to a file called "My Lut.cube" located on the desktop:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>export as lut</b></span> <b>the</b> <span style="color:blue;font-style:italic;">color adjustments</span> <b>of the first</b> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span> <span style="color:blue;">to</span> <span style="color:blue;font-style:italic;">file</span> ((<span style="color:#0016B0;"><b>path to</b></span> <span style="color:#4415B0;font-style:italic;">desktop</span> <span style="color:#0016B0;">as</span> <span style="color:blue;font-style:italic;">text</span>) & "My Lut.cube")</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="flatten" code="PProflst" description="Flatten the styles of a layer.">
            <direct-parameter type="styles"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Flatten the styles of the first layer in the doucment:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>flatten</b></span> <b>the</b> <span style="color:blue;font-style:italic;">styles</span> <b>of the first</b> <span style="color:blue;font-style:italic;">layer</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="reset" code="PProrsst" description="Reset the styles of a layer.">
            <direct-parameter type="styles"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Reset the styles of the first layer in the doucment:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>reset</b></span> <b>the</b> <span style="color:blue;font-style:italic;">styles</span> <b>of the first</b> <span style="color:blue;font-style:italic;">layer</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        
        <!-- Arrange Menu -->
        
        <command name="ungroup" code="PProungr" description="Ungroup a group layer.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Ungroup the second group layer of the current document:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>ungroup</b></span> <b>the front</b> <span style="color:blue;font-style:italic;">document's</span> <b>second</b> <span style="color:blue;font-style:italic;">group layer</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="merge" code="PPromrge" description="Merge multiple layers into one.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <parameter name="layers" code="Layr" description="A list of layers to merge." optional="yes">
                <type type="layer" list="yes"/>
                <cocoa key="Layers"/>
            </parameter>
            <result type="layer" description="The ID of the new layer." />
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Merge layers the first and second layers:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>merge</b></span> <span style="color:blue;">layers</span> {<span style="color:blue;font-style:italic;">layer</span> 1, <span style="color:blue;font-style:italic;">layer</span> 2}</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="merge all" code="PPromral" description="Merge every layer into one.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <result type="layer" description="The instance of the new layer." />
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Merge every layer in the current document:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>merge all</b></span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="merge visible" code="PPromrvs" description="Merge every visible layer into one.">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <result type="layer" description="The ID of the new layer." />
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Merge every visible layer and store the reference to the new layer in a variable:</p>
                        <p style="font-family:Verdana, sans-serif;text-indent:1.5em;"><b>set</b> <span style="color:#408000;">mergedLayers</span> <b>to</b> <span style="color:blue;"><b>merge visible</b></span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <command name="select all layers" code="PProsalL" description="Select all layers in a document,">
            <direct-parameter type="document"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Select every layer in the current document:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>select all layers</b></span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        
        <!-- Layer -->
        
        <command name="select" code="PProsllr" description="Select one or multiple layers.">
            <direct-parameter type="specifier"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Select every layer whose name begins with the letter P.:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>select</b></span> (<b>every</b> <span style="color:blue;font-style:italic;">layer</span> <b>whose</b> <span style="color:#6C05D3;">name</span> <b>begins with</b> "P")</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        
        <!-- Application -->
        
        <command name="make document from clipboard" code="PProdccl" description="Make a new document from an image in  the clipboard.">
            <result type="document" description="The new document." />
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Make a new document from an image in the clipboard:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>make document from clipboard</b></span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </command>
        <class name="application" code="capp" description="The Pixelmator Pro application." inherits="application">
            <cocoa class="Pixelmator.Application"/>
            <property name="autosave enabled" code="Aats" type="boolean" description="Is autosave enabled?" access="rw">
                <cocoa key="scriptAutoSaveEnabled" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.preferences"/>
            </property>
            <property name="appearance" code="Aapr" type="application appearance" description="The appearance of the application." access="rw">
                <cocoa key="scriptAppearance" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.preferences"/>
            </property>
            <property name="load hdr content" code="Aahd" type="boolean" description="Is HDR content loading enabled?" access="rw">
                <cocoa key="scriptHDRLoadingEnabled" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.preferences"/>
            </property>
            <property name="image opening workflow" code="Aiow" type="image opening workflow" description="How images in non-native formats are opened – whether they're opened in their original format whenever possible, or always imported as Pixelmator Pro files." access="rw">
                <cocoa key="scriptLossyImageFormatOpeningBehavior" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.preferences"/>
            </property>
            <property name="sidecar enabled" code="Asde" type="boolean" description="Whether layers and edits will be preserved in a sidecar file linked to the original image file. Returns true only if the image the opening workflow is set to &quot;open in original format&quot; and sidecar is enabled, false otherwise." access="rw">
                <cocoa key="scriptSidecarEnabled" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.preferences"/>
            </property>
            <property name="sidecar location" code="Asdl" description="The location (iCloud or Pictures) that sidecar files are currently being saved in." access="rw">
                <type type="sidecar location" />
                <cocoa key="scriptSidecarLocation" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.preferences"/>
            </property>
            <property name="build number" code="Abnv" type="text" description="The build number of the current version." access="r">
                <cocoa key="scriptBundleVersion" />
            </property>
            <responds-to command="make document from clipboard">
                <cocoa method="handleDocumentFromClipboardScriptCommand:"/>
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit"/>
            </responds-to>
        </class>
        
        <!-- Document -->
        
        <class name="document" code="docu" description="The Pixelmator Pro document." inherits="document">
            <cocoa class="PXMPro.Document"/>
            <property name="class" code="pcls" type="type" access="r" description="The object&apos;s class.">
                <cocoa key="classCode"/>
            </property>
            <property name="properties" code="pALL" type="record" access="r" description="All of this object&apos;s properties returned in a single record.">
                <cocoa key="scriptingProperties"/>
            </property>
            <property name="id" code="ID  " type="text" access="r" description="The unique identifier of the document.">
              <cocoa key="scriptUniqueID"/>
            </property>
            <property name="sidecar file" code="Dsdr" access="r" hidden="yes" description="The associated sidecar file for the image, if one exists.">
                <type type="file" />
                <type type="missing value" />
                <cocoa key="scriptSidecarFile" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info" />
            </property>
            <property name="data reference" code="datr" description="Used for automated publishing, the data reference may hold a reference to a disk item, or database record, related to the contents of the layer." access="rw">
                <type type="text" />
                <cocoa key="scriptDataReference" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info" />
            </property>
            <property name="width" code="widD" type="real" description="The width of the document (in pixels)." access="r">
                <cocoa key="scriptWidthInPixels" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info" />
            </property>
            <property name="height" code="Hgth" type="real" description="The height of the document (in pixels)." access="r">
                <cocoa key="scriptHeightInPixels" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info" />
            </property>
            <property name="resolution" code="Docr" type="real" description="The resolution of the document (in pixels per inch)." access="r">
                <cocoa key="scriptResolution" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info" />
            </property>
            <property name="bits per channel" code="Docb" type="integer" description="The color depth of the document." access="rw">
                <cocoa key="scriptBitsPerChannel" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info" />
            </property>
            <property name="color profile" code="Docs" type="text" description="The name of the document's color profile." access="r">
                <cocoa key="scriptColorSpace" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info" />
            </property>
            <property name="display hdr content" code="Dohd" type="boolean" description="Is display HDR content enabled?" access="rw">
                <cocoa key="scriptHDREnabled" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info" />
            </property>
            <property name="document info" code="Dinf" type="document info" access="r" description="The document's metada information.">
                <cocoa key="scriptDocumentInfo" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info" />
            </property>
            <property name="current layer" code="Slct" description="The top-most selected layer." type="layer" access="rw">
                <cocoa key="scriptingCurrentLayer"/>
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </property>
            <property name="selected layers" code="Slls" description="A list of all selected layers." access="rw">
                <cocoa key="scriptingSelectedLayers" />
                <type type="layer" list="yes" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </property>
            <property name="selection bounds" code="sbnd" description="The bounds of any currently active selection." access="r">
                <type type="integer" list="yes"/>
                <cocoa key="scriptSelectionBounds" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </property>
            <element type="layer" access="r">
                <cocoa key="scriptLayers"/>
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </element>
            <element type="image layer">
                <cocoa key="scriptImages" />
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </element>
            <element type="group layer">
                <cocoa key="scriptGroups" />
