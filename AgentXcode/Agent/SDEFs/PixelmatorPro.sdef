<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE dictionary SYSTEM "file://localhost/System/Library/DTDs/sdef.dtd"
[
    <!ELEMENT class (cocoa?, access-group*, type?, (contents | documentation | element | property | responds-to | synonym | xref)*)>
]>
<dictionary xmlns:xi="http://www.w3.org/2003/XInclude" title="Pixelmator Pro Terminology">
    <xi:include href="file:///System/Library/ScriptingDefinitions/CocoaStandard.sdef" xpointer="xpointer(/dictionary/suite)" />
    <suite name="Pixelmator Pro Suite" code="PixP" description="Classes and commands for Pixelmator Pro.">
        <enumeration name="saveable file format" code="savf">
            <enumerator name="Pixelmator Pro" code="Ppxd" description="The native Pixelmator Pro file format.">
                <cocoa string-value="com.pixelmatorteam.pixelmator.document.binary" />
            </enumerator>
            <enumerator name="HEIC" code="Phic" description="HEIC">
                <cocoa string-value="public.heic" />
            </enumerator>
            <enumerator name="JPEG" code="Pjpg" description="JPEG">
                <cocoa string-value="public.jpeg" />
            </enumerator>
            <enumerator name="PNG" code="Ppng" description="PNG">
                <cocoa string-value="public.png" />
            </enumerator>
            <enumerator name="WebP" code="Pwbp" description="WebP">
                <cocoa string-value="org.webmproject.webp" />
            </enumerator>
            <enumerator name="TIFF" code="Ptif" description="TIFF">
                <cocoa string-value="public.tiff" />
            </enumerator>
            <enumerator name="SVG" code="Psvg" description="SVG">
                <cocoa string-value="public.svg-image" />
            </enumerator>
            <enumerator name="GIF" code="Pgif" description="GIF">
                <cocoa string-value="com.compuserve.gif" />
            </enumerator>
            <enumerator name="PSD" code="Ppsd" description="Adobe Photoshop document.">
                <cocoa string-value="com.adobe.photoshop-image" />
            </enumerator>
        </enumeration>
        <enumeration name="export format" code="Pxef">
            <enumerator name="PNG" code="Ppng" description="PNG">
                <cocoa string-value="public.png" />
            </enumerator>
            <enumerator name="TIFF" code="Ptif" description="TIFF">
                <cocoa string-value="public.tiff" />
            </enumerator>
            <enumerator name="JPEG" code="Pjpg" description="JPEG">
                <synonym name="JPG"/>
                <cocoa string-value="public.jpeg" />
            </enumerator>
            <enumerator name="HEIC" code="Phic" description="HEIC">
                <cocoa string-value="public.heic" />
            </enumerator>
            <enumerator name="GIF" code="Pgif" description="GIF">
                <cocoa string-value="com.compuserve.gif" />
            </enumerator>
            <enumerator name="JPEG2000" code="Pjp2" description="JPEG 2000">
                <cocoa string-value="public.jpeg-2000" />
            </enumerator>
            <enumerator name="BMP" code="Pbmp" description="BMP">
                <cocoa string-value="com.microsoft.bmp" />
            </enumerator>
            <enumerator name="WebP" code="Pwbp" description="WebP">
                <cocoa string-value="org.webmproject.webp" />
            </enumerator>
            <enumerator name="SVG" code="Psvg" description="SVG">
                <cocoa string-value="public.svg-image" />
            </enumerator>
            <enumerator name="PDF" code="Ppdf" description="PDF">
                <cocoa string-value="com.adobe.pdf" />
            </enumerator>
            <enumerator name="PSD" code="Ppsd" description="Adobe Photoshop document.">
                <cocoa string-value="com.adobe.photoshop-image" />
            </enumerator>
            <enumerator name="Pixelmator Pro" code="Ppxd" description="The native Pixelmator Pro file format.">
                <cocoa string-value="com.pixelmatorteam.pixelmator.document.binary" />
            </enumerator>
            <enumerator name="Motion" code="Pmtn" description="Motion project.">
                <cocoa string-value="com.apple.motion.project" />
            </enumerator>
            <enumerator name="MP4" code="mp4v" description="MP4">
                <cocoa string-value="public.mpeg-4" />
            </enumerator>
            <enumerator name="QuickTime Movie" code="QTmv" description="QuickTime Movie">
                <cocoa string-value="com.apple.quicktime-movie" />
            </enumerator>
            <enumerator name="Animated GIF" code="aGIF" description="Animated GIF">
                <cocoa string-value="com.compuserve.gif.animated" />
            </enumerator>
            <enumerator name="Animated PNG" code="aPNG" description="Animated PNG">
                <cocoa string-value="public.png.animated" />
            </enumerator>
            <enumerator name="OpenEXR" code="Pexr" description="OpenEXR">
                <cocoa string-value="com.ilm.openexr-image" />
            </enumerator>
            <enumerator name="HDR JPEG" code="Phjp" description="HDR JPEG">
                <synonym name="HDR JPG"/>
                <cocoa string-value="public.jpeg.hdr" />
            </enumerator>
            <enumerator name="HDR HEIC" code="Phid" description="HDR HEIC">
                <cocoa string-value="public.heic.hdr" />
            </enumerator>
            <enumerator name="HDR AVIF" code="Pavd" description="HDR AVIF">
                <cocoa string-value="public.avif.hdr" />
            </enumerator>
            <enumerator name="HDR PNG" code="Ppnd" description="HDR PNG">
                <cocoa string-value="public.png.hdr" />
            </enumerator>
        </enumeration>
        <record-type name="export options" code="Pxeo">
            <property name="compression factor" code="Pxic" type="integer" description="The amount of compression applied to the image during export, ranging from 1 (maximum compression, lowest quality) to 100 (lossless compression, highest quality). This option only pertains to JPEG, JPEG-2000, HEIC and WebP format images.">
                <cocoa key="ExportImageCompression" />
            </property>
            <property name="bits per channel" code="Docb" type="integer" description="The color depth of the image in bits per channel, either 8 or 16.">
                <cocoa key="ExportBitsPerChannel" />
            </property>
            <property name="color profile" code="Docs" type="text" description="The name of the color profile used for the image.">
                <cocoa key="ExportColorSpace" />
            </property>
            <property name="frame rate" code="Pxfr" type="real" description="The frame rate of the exported video or animated image.">
                <cocoa key="ExportImageFrameRate" />
            </property>
        </record-type>
        <enumeration name="export for web format" code="Pxew">
            <enumerator name="PNG" code="Ppng" description="PNG">
                <cocoa string-value="public.png" />
            </enumerator>
            <enumerator name="JPEG" code="Pjpg" description="JPEG">
                <cocoa string-value="public.jpeg" />
            </enumerator>
            <enumerator name="GIF" code="Pgif" description="GIF">
                <cocoa string-value="com.compuserve.gif" />
            </enumerator>
            <enumerator name="SVG" code="Psvg" description="SVG">
                <cocoa string-value="public.svg-image" />
            </enumerator>
            <enumerator name="WebP" code="Pwbp" description="WebP">
                <cocoa string-value="org.webmproject.webp" />
            </enumerator>
        </enumeration>
        <record-type name="export for web options" code="Pxwo">
            <property name="compression factor" code="Pxic" type="integer" description="The amount of compression applied to the image during export, ranging from 1 (maximum compression, lowest quality) to 100 (lossless compression, highest quality). This option only pertains to JPEG and WebP images.">
                <cocoa key="ExportForWebImageCompression" />
            </property>
            <property name="advanced compression" code="Pxac" type="boolean" description="Export the image with advanced compression. This option only pertains to PNG images.">
                <cocoa key="ExportForWebAdvancedCompression" />
            </property>
            <property name="reduce colors" code="Px8b" type="boolean" description="Export the image with an 8-bit color palette (256 colors). This option only pertains to PNG images.">
                <cocoa key="ExportForWeb8bitColor" />
            </property>
            <property name="keep transparency" code="Pxkt" type="boolean" description="Preserve transparency during export or replace trasparent areas with white. This option only pertains to PNG and GIF images.">
                <cocoa key="ExportForWebKeepTransparency" />
            </property>
            <property name="convert to sRGB" code="Psrb" type="boolean" description="Convert colors to sRGB and don't include the color profile in the exported image.">
                <cocoa key="ExportForWebConvertToSRGB" />
            </property>
            <property name="scale" code="Pxsc" type="integer" description="The scale factor to use when exporting.">
                <cocoa key="ExportForWebScale" />
            </property>
        </record-type>
        <record-type name="replace text properties" code="Pxtr">
            <property name="match words" code="Ptmw" type="boolean" description="When true, replaces text only if it is not part of another word.">
                <cocoa key="ReplaceTextMatchWords" />
            </property>
            <property name="case sensitive" code="Ptcs" type="boolean" description="Treats lowercase and uppercase characters as distinct.">
                <cocoa key="ReplaceTextCaseSensitive" />
            </property>
        </record-type>
