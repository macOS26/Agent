            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Add a new effects layer, storing a reference to it in a variable, then add a new gaussian effect in the effects layer (again, storing a reference to it in a variable), then set its radius to 5:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                            <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;margin-top:-6px;padding-left:10em;text-indent:-6em;">
                            <b>set</b> <span style="color:#408000;">effectsLayer</span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>effects layer</i> at</span> <b>the beginning of</b> <span style="color:blue;"><i>layers</i></span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;margin-top:-6px;padding-left:10em;text-indent:-6em;">
                            <b>set</b> <span style="color:#408000;">gaussianEffect</span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>gaussian effect</i> at</span> <b>the beginning of</b> <span style="color:blue;"><i>effects</i></span> <b>of</b> <span style="color:#408000;">effectsLayer</span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>set the</b> <span style="color:#6C05D3;">radius</span> <b>of</b> <span style="color:#408000;">gaussianEffect</span> <b>to</b> 5
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="shape layer" code="PrSh" description="A shape layer." inherits="layer" plural="shape layers">
            <cocoa class="Pixelmator.ScriptingShapeLayer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <property name="constrain proportions" code="CnPr" type="boolean" access="rw" description="Whether or not constraint proportions is enabled.">
              <cocoa key="scriptConstrainProportions"/>
              <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </property>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a new shape layer (a rectangle, by default) behind the second layer in the current document:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                        <span style="color:blue;"><b>make</b></span> <span style="color:blue;">new <i>shape layer</i> at</span> <b>behind</b> <span style="color:blue;font-style:italic;">layer</span> 2 <b>of the front</b> <span style="color:blue;font-style:italic;">document</span></p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="rectangle shape layer" code="ShRc" description="A rectangle shape layer" inherits="shape layer" plural="rectangle shape layers">
            <cocoa class="Pixelmator.ScriptingRectangleShapeLayer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a new shape layer, store the reference to it in a variable, set its size to 50 pixels by pixels, then set its color to red:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                            <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;margin-top:-6px;padding-left:10em;text-indent:-6em;">
                            <b>set</b> <span style="color:#408000;">newShape</span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>rectangle shape layer</i> at</span> <b>the beginning of</b> <span style="color:blue;"><i>layers</i> with properties</span> {<span style="color:#6C05D3;">width</span>:50, <span style="color:#6C05D3;">height</span>:50}
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>tell the</b> <span style="color:blue;font-style:italic;">styles</span> <b>of</b> <span style="color:#408000;">newShape</span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <b>set the</b> <span style="color:#6C05D3;">fill color</span> <b>to</b> {65535, 0, 0}
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="rounded rectangle shape layer" code="ShRr" description="A rounded rectangle shape layer." inherits="shape layer" plural="rounded rectangle shape layers">
            <cocoa class="Pixelmator.ScriptingRoundedRectangleShapeLayer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <property name="corner radius" code="RRCr" type="real" access="r" description="The corner radius. A valid value is from 0 to the width or height of the rectangle (whichever is smaller) divided by 2.">
              <cocoa key="scriptRoundedRectangleCornerRadius"/>
              <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </property>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a new rounded rectangle shape layer whose top left corner is at 300 pixels down and 200 pixels across with a height of 1600 by 900 pixels and corner radius of 50 pixels:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <span style="color:blue;"><b>make</b> new <i>rounded rectangle shape layer</i> at</span> <b>the beginning of</b> <span style="color:blue;font-style:italic;">layers</span> <b>of the front</b> <span style="color:blue;"><i>document</i> with properties</span> {<span style="color:#6C05D3;">position</span>:{300, 200}, <span style="color:#6C05D3;">width</span>:1600, <span style="color:#6C05D3;">height</span>:900, <span style="color:#6C05D3;">corner radius</span>:50}</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="ellipse shape layer" code="ShEl" description="An ellipse shape layer." inherits="shape layer" plural="ellipse shape layers">
            <synonym name="circle shape layer" />
            <synonym name="oval shape layer" />
            <cocoa class="Pixelmator.ScriptingEllipseShapeLayer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a new ellipse shape layer at 50 pixels down and 50 pixels across with a size of 300 pixels by 300 pixels, store the reference to it in a variable, then set its color to green:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                            <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;margin-top:-6px;padding-left:10em;text-indent:-6em;">
                            <b>set</b> <span style="color:#408000;">theCircle</span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>ellipse shape layer</i> at</span> <b>the beginning of</b> <span style="color:blue;"><i>layers</i> with properties</span> {<span style="color:#6C05D3;">position</span>:{50, 50}, <span style="color:#6C05D3;">width</span>:300, <span style="color:#6C05D3;">height</span>:300}
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>tell the</b> <span style="color:blue;font-style:italic;">styles</span> <b>of</b> <span style="color:#408000;">theCircle</span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <b>set the</b> <span style="color:#6C05D3;">fill color</span> <b>to</b> {0, 65535, 0}
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="polygon shape layer" code="ShPo" description="A polygon shape layer." inherits="shape layer" plural="polygon shape layers">
            <cocoa class="Pixelmator.ScriptingPolygonShapeLayer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <property name="sides" code="SdCn" type="integer" access="r" description="The number (from 3 to 11) of polygon sides.">
              <cocoa key="scriptPolygonSides"/>
              <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </property>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a new polygon shape layer with 6 sides, whose top left corner is at 100 pixels down and 200 pixels across with a height of 500 by 500 pixels, insert it after the fourth layer, and store the reference to it in a variable:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to set</b> <span style="color:#408000;">theHexagon</span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>polygon shape layer</i> at</span> <b>after</b> <span style="color:blue;font-style:italic;">layer</span> 4 <span style="color:blue;">with properties</span> {<span style="color:#6C05D3;">position</span>:{100, 200}, <span style="color:#6C05D3;">width</span>:500, <span style="color:#6C05D3;">height</span>:500, <span style="color:#6C05D3;">sides</span>:6}</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="star shape layer" code="SHSt" description="A star shape layer." inherits="shape layer" plural="star shape layers">
            <cocoa class="Pixelmator.ScriptingStarShapeLayer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <property name="star points" code="StPn" type="integer" access="r" description="The number (from 3 to 20) of star points.">
              <cocoa key="scriptStarPoints"/>
              <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </property>
            <property name="star radius" code="StRd" type="real" access="r" description="The radius of the star in percent, from 10 to 100.">
              <cocoa key="scriptStarRadius"/>
              <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </property>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a new star shape layer with 8 star points and a radius of 60 percent, whose top left corner is at 100 pixels down and 200 pixels across with a height of 500 by 500 pixels:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <span style="color:blue;"><b>make</b> new <i>star shape layer</i> at</span> <b>the beginning of</b> <span style="color:blue;font-style:italic;">layers</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span> <span style="color:blue;">with properties</span> {<span style="color:#6C05D3;">position</span>:{100, 200}, <span style="color:#6C05D3;">width</span>:500, <span style="color:#6C05D3;">height</span>:500, <span style="color:#6C05D3;">star points</span>:6, <span style="color:#6C05D3;">star radius</span>:60}</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="line shape layer" code="ShLn" description="A line shape layer." inherits="shape layer" plural="line shape layers">
            <cocoa class="Pixelmator.ScriptingLineShapeLayer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
        </class>
        <class name="text layer" code="PrTx" description="A text layer." inherits="layer" plural="text layers">
            <cocoa class="Pixelmator.ScriptingTextLayer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <responds-to command="convert into shape">
                <cocoa method="handleConvertIntoShapeScriptCommand:" />
            </responds-to>
            <contents name="text content" code="Tact" description="The text of the text layer." type="rich text">
                <cocoa key="scriptTextContent"/>
                <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </contents>
            <property name="horizontal alignment" code="tiha" type="tAHT" description="The horizontal alignment of text content in the text layer.">
                <cocoa key="scriptHorizontalAlignment" />
            </property>
            <property name="vertical alignment" code="txVA" type="tAVT" description="The vertical alignment of text content in the text layer.">
                <cocoa key="scriptVerticalAlignment" />
            </property>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Create a new text layer, change its text to "Hello World" and store the reference to the layer in a variable, then set the color of the text to black, the font to Helvetica, and the size too 100 pixels:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                            <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;margin-top:-6px;padding-left:10em;text-indent:-6em;">
                            <b>set</b> <span style="color:#408000;">myText</span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>text layer</i> at</span> <b>the beginning of</b> <span style="color:blue;"><i>layers</i> with properties</span> {<span style="color:#6C05D3;">text content</span>:"Hello World"}
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>tell the</b> <span style="color:#6C05D3;">text content</span> <b>of</b> <span style="color:#408000;">myText</span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <b>set its</b> <span style="color:blue;font-style:italic;">color</span> <b>to</b> {0, 0, 0}
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">font</span> <b>to</b> "Helvetica"
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">size</span> <b>to</b> 100
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="video layer" code="PrVi" description="A video layer." inherits="layer" plural="video layers">
            <cocoa class="Pixelmator.ScriptingVideoLayer"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
        </class>
        <class name="color adjustments" code="PrCA" description="The color adjustments of a layer.">
            <cocoa class="Pixelmator.ScriptingColorAdjustments"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <property name="temperature" code="CAtm" type="integer" access="rw" description="Add a blue (from -1 to -200) or yellow (from 1 to 200) tint to a layer to adjust its white balance." />
            <property name="tint" code="CAtn" type="integer" access="rw" description="Add a green (from -1 to -200) or magenta (from 1 to 200) tint to a layer to adjust its white balance." />
            <property name="hue" code="CAhu" type="integer" access="rw" description="Shift the hues of every color in a layer along the color spectrum. Supported values are from -100 to 100." />
            <property name="saturation" code="CAsa" type="integer" access="rw" description="Adjust the saturation of a layer. Supported values are from -100 to 100." />
            <property name="vibrance" code="CAvi" type="integer" access="rw" description="Adjust the vibrance of a layer. Supported values are from -200 to 200." />
            <property name="exposure" code="CAex" type="integer" access="rw" description="Adjust the exposure of a layer. Supported values are from -400 to 400." />
            <property name="highlights" code="CAhi" type="integer" access="rw" description="Adjust the highlights of a layer. Supported values are from -100 to 100." />
            <property name="shadows" code="CAsh" type="integer" access="rw" description="Adjust the shadows of a layer. Supported values are from -100 to 100." />
            <property name="brightness" code="CAbr" type="integer" access="rw" description="Adjust the brightness of a layer. Supported values are from -200 to 200." />
            <property name="contrast" code="CAco" type="integer" access="rw" description="Adjust the contrast of a layer. Supported values are from -200 to 200." />
            <property name="black point" code="CAbp" type="integer" access="rw" description="Adjust the highlights of a layer. Supported values are from -200 to 200." />
            <property name="texture" code="CAtx" type="integer" access="rw" description="Adjust the texture of a layer. Supported values are from -100 to 100." />
            <property name="clarity" code="CAcl" type="integer" access="rw" description="Adjust the clarity of a layer. Supported values are from -100 to 100." />
            <property name="black and white" code="CAbw" type="boolean" access="rw" description="Turn the colors of a layer to black and white." />
            <property name="sepia" code="CAsp" type="boolean" access="rw" description="Convert the colors of a layer to shades of sepia." />
            <property name="invert" code="CAin" type="boolean" access="rw" description="Invert the colors of a layer." />
            <property name="fade" code="CAfd" type="integer" access="rw" description="Fade the shadows of a layer. Supported values are from 0 to 200." />
            <property name="vignette" code="CAve" type="boolean" access="rw" description="Apply a vignette to a layer." />
            <property name="vignette exposure" code="CAvx" type="integer" access="rw" description="Adjust the exposure of the vignette. Supported values are from -200 to 200." />
            <property name="vignette black point" code="CAvb" type="integer" access="rw" description="Adjust the black point of the vignette. Supported values are from -200 to 200." />
            <property name="vignette softness" code="CAvs" type="integer" access="rw" description="Adjust the softness of the vignette. Supported values are from 0 to 100." />
            <property name="grain" code="CAgr" type="integer" access="rw" description="Add film grain to a layer and adjust its intensity. Supported values are from 0 to 100." />
            <property name="grain size" code="CAgs" type="integer" access="rw" description="Adjust the size of grain particles. Supported values are from 0 to 400." />
            <property name="sharpen" code="CAsr" type="integer" access="rw" description="Sharpen a layer. Supported values are from 0 to 100." />
            <property name="sharpen radius" code="CAsd" type="real" access="rw" description="Adjust the radius of the sharpening effect. Supported values are from 0 to 100." />
            <property name="custom lut" code="CAlt" access="rw" description="Apply a 3D LUT to a layer. The value of this property must be set to a LUT file in a supported format.">
                <type type="file" />
                <type type="missing value" />
            </property>
            <responds-to command="flatten">
                <cocoa method="handleFlattenScriptCommand:"/>
            </responds-to>
            <responds-to command="reset">
                <cocoa method="handleResetScriptCommand:"/>
            </responds-to>
            <responds-to command="export as lut">
                <cocoa method="handleExportAsLUTScriptCommand:"/>
            </responds-to>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Brighten the shadows of the last layer of the current document by 20%:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <b>set the</b> <span style="color:#6C05D3;">shadows</span> <b>of the</b> <span style="color:blue;font-style:italic;">color adjustments</span> <b>of the last</b> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> 20</p>
                        </div>
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Turn the colors of the second layer to black and white:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to set the</b> <span style="color:#6C05D3;">black and white</span> <b>of the</b> <span style="color:blue;font-style:italic;">color adjustments</span> <b>of</b> <span style="color:blue;font-style:italic;">layer</span> 2 <b>to</b> <span style="color:#6C05D3;font-style:italic;">true</span></p>
                        </div>
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Adjust the temperature, exposure, and brightness of the first layer of the current document:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:5em;text-indent:-3.5em;">
                            <b>tell the</b> <span style="color:blue;font-style:italic;">color adjustments</span> <b>of the first</b> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">temperature</span> <b>to</b> 20
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">exposure</span> <b>to</b> -10
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">brightness</span> <b>to</b> -15
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Open an image on the desktop called Kitty and store the reference to the document in a variable, automatically enhance the image, add a vignette with the default settings, fade the shadows slightly, then export the changes back to the same image:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                            <b>set</b> <span style="color:#408000;">myCatPic</span> <b>to</b> <span style="color:blue;"><b>open</b> file</span> ((<span style="color:#0016B0;"><b>path to</b></span> <span style="color:#4415B0;font-style:italic;">desktop</span> <span style="color:#0016B0;">as</span> <span style="color:blue;font-style:italic;">text</span>) & "Kitty.png")
                        </p>
                        <p style="font-family:Verdana,sans-serif;margin-top:-6px;text-indent:1.5em;">
                            <b>tell</b> <span style="color:#408000;">myCatPic</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>tell its first</b> <span style="color:blue;font-style:italic;">layer</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <span style="color:blue;"><b>enhance</b></span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <b>tell its</b> <span style="color:blue;font-style:italic;">color adjustments</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:9em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">vignette</span> <b>to</b> <span style="color:#6C05D3;font-style:italic;">true</span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:9em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">fade</span> <b>to</b> 10
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:6.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <span style="color:blue;"><b>export</b></span> <span style="color:#408000;">myCatPic</span> <span style="color:blue;">to <i>file</i></span> ((<span style="color:#0016B0;"><b>path to</b></span> <span style="color:#4415B0;font-style:italic;">desktop</span> <span style="color:#0016B0;">as</span> <span style="color:blue;font-style:italic;">text</span>) & "Kitty.png") <span style="color:blue;">as</span> <span style="color:#6C05D3;font-style:italic;">PNG</span>
                        </p>
                        </div>
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Apply a custom LUT to a layer, showing a dialog that lets you choose the LUT from a location on your Mac:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:5em;text-indent:-3.5em;">
                            <b>tell the</b> <span style="color:blue;font-style:italic;">color adjustments</span> <b>of the first</b> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">custom lut</span> <b>to</b> <span style="color:#0016B0;"><b>choose file</b> with prompt</span> "Choose the LUT you'd like to apply to the layer:"
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="styles" code="PrST" description="The layer styles of a layer.">
            <cocoa class="Pixelmator.ScriptingStyles"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <property name="fill color" code="flcl" type="color" access="rw" description="The color of the layer fill. Expressed as an RGB value consisting of a list of three color values from 0 to 65535. ex: Blue = {0, 0, 65535}." />
            <property name="fill opacity" code="FLop" type="integer" access="rw" description="The opacity of the layer fill. Supported values are from 0 to 100." />
            <property name="fill blend mode" code="FLbm" type="blend mode" access="rw" description="The blend mode of the color fill." />
            <property name="stroke width" code="STop" type="real" access="rw" description="The width of the stroke around a layer. Supported values are from 0 to 200." />
            <property name="stroke position" code="STps" type="stroke position" access="rw" description="The position of the stroke." />
            <property name="stroke type" code="STtp" type="stroke type" access="rw" description="The stroke type."  hidden="yes" />
            <property name="stroke color" code="STcl" type="color" access="rw" description="The color fo the stroke. Expressed as an RGB value consisting of a list of three color values from 0 to 65535. ex: Blue = {0, 0, 65535}." />
            <property name="stroke opacity" code="STro" type="integer" access="rw" description="The opacity of the layer stroke. Supported values are from 0 to 100." />
            <property name="shadow blur" code="SHbl" type="real" access="rw" description="The strength of the blur of the shadow layer style, in pixels from 0 to 100." />
            <property name="shadow distance" code="SHds" type="real" access="rw" description="The distance of the shadow from the layer, in pixels from 0 to 400." />
            <property name="shadow angle" code="SHan" type="real" access="rw" description="The angle of the shadow, in degrees from 0 to 359." />
            <property name="shadow color" code="SHco" type="color" access="rw" description="The color of the shadow. Expressed as an RGB value consisting of a list of three color values from 0 to 65535. ex: Blue = {0, 0, 65535}." />
            <property name="shadow opacity" code="SHop" type="integer" access="rw" description="The opacity of the shadow. Supported values are from 0 to 100." />
            <property name="inner shadow blur" code="ISsb" type="real" access="rw" description="The strength of the blur of the inner shadow layer style, in pixels from 0 to 100." />
            <property name="inner shadow distance" code="ISsd" type="real" access="rw" description="The distance of the inner shadow from the layer, in pixels from 0 to 400." />
            <property name="inner shadow angle" code="ISsa" type="real" access="rw" description="The angle of the inner shadow, in degrees from 0 to 359." />
            <property name="inner shadow color" code="ISsc" type="color" access="rw" description="The color of the inner shadow. Expressed as an RGB value consisting of a list of three color values from 0 to 65535. ex: Blue = {0, 0, 65535}." />
            <property name="inner shadow opacity" code="ISso" type="integer" access="rw" description="The opacity of the inner shadow. Supported values are from 0 to 100." />
            <property name="inner shadow blend mode" code="ISbl" type="blend mode" access="rw" description="The blend mode of the inner shadow." />
            <responds-to command="flatten">
                <cocoa method="handleFlattenScriptCommand:"/>
            </responds-to>
            <responds-to command="reset">
                <cocoa method="handleResetScriptCommand:"/>
            </responds-to>
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Edit the stroke width and stroke position of the first layer of the front document:</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                            <b>tell the</b> <span style="color:blue;font-style:italic;">styles</span> <b>of the first</b> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">stroke width</span> <b>to</b> 10
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>set its</b> <span style="color:#6C05D3;">stroke position</span> <b>to</b> <span style="color:#6C05D3;font-style:italic;">outside</span>
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="document info" code="PrDi" description="The IPTC metada of the document.">
            <cocoa class="Pixelmator.ScriptingDocumentInfo"/>
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.info" />
            <property name="class" code="pcls" type="type" access="r" description="The object&apos;s class.">
                <cocoa key="classCode"/>
            </property>
            <property name="properties" code="pALL" type="record" access="r" description="All of this object&apos;s properties returned in a single record.">
                <cocoa key="scriptingProperties"/>
            </property>
            <property name="author" code="Di01" type="text"/>
            <property name="author position" code="Di02" type="text"/>
            <property name="caption" code="Di03" type="text">
                <synonym name="description" />
            </property>
            <property name="caption writer" code="Di04" type="text"/>
            <property name="category" code="Di05" type="text"/>
            <property name="city" code="Di06" type="text"/>
            <property name="copyright notice" code="Di07" type="text"/>
            <property name="copyrighted" code="Di08" type="DiCp"/>
            <property name="country" code="Di09" type="text"/>
            <property name="creation date" code="Di10" type="text"/>
            <property name="credit" code="Di11" type="text"/>
            <property name="headline" code="Di13" type="text"/>
            <property name="instructions" code="Di14" type="text"/>
            <property name="job name" code="Di15" type="text"/>
            <property name="keywords" code="Di16" description="list of keywords">
                <type type="text" list="yes"/>
            </property>
            <property name="owner url" code="Di17" type="text"/>
            <property name="province or state" code="Di18" type="text"/>
            <property name="source" code="Di19" type="text"/>
            <property name="supplemental categories" code="Di20">
                <type type="text" list="yes"/>
            </property>
            <property name="title" code="Di21" type="text"/>
            <property name="transmission reference" code="Di22" type="text"/>
            <property name="urgency" code="Di23" type="DiUr"/>
            <property name="location" code="IPlo" description="The GPS latitude and longitude, in an ordered list of 2 numbers or missing values.  Latitude in range -90.0 to 90.0, longitude in range -180.0 to 180.0." >
                <type type="real" list="yes" />
                <type type="missing value" list="yes" />
            </property>
            <property name="altitude" code="alti" type="real" access="rw" description="The GPS altitude in meters." />
             <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Set the IPTC title of the document to "Whirlwind":</p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;">
                            <b>tell the front</b> <span style="color:blue;font-style:italic;">document</span>
                        </p>
                        <p style="font-family:Verdana, sans-serif;text-indent:4em;margin-top:-6px;">
                            <b>set the</b> <span style="color:#6C05D3;">title</span> <b>of its</b> <span style="color:#6C05D3;">document info</span> <b>to</b> "Whirlwind"
                        </p>
                        <p style="font-family:Verdana,sans-serif;text-indent:1.5em;margin-top:-6px;">
                            <b>end tell</b>
                        </p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
    </suite>
    <suite name="Pixelmator Pro Effects Suite" code="Pref" description="Classes and commands for Pixelmator Pro effects.">
        <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
        <class name="effect" code="PrEf" description="An effect applied to a layer." inherits="item" plural="effects">
            <cocoa class="Pixelmator.ScriptingEffect"/>
            <property name="class" code="pcls" type="type" access="r" description="The object&apos;s class.">
                <cocoa key="classCode"/>
            </property>
            <property name="properties" code="pALL" type="record" access="r" description="All of this object&apos;s properties returned in a single record.">
                <cocoa key="scriptingProperties"/>
            </property>
            <property name="id" code="ID  " type="text" access="r" description="The unique identifier of the effect.">
              <cocoa key="scriptUniqueID"/>
            </property>
            <property name="index" code="pidx" type="integer" access="r" description="The index of this instance of the object."/>
            <property name="name" code="pnam" type="text" access="r" description="The name of the effect.">
                <cocoa key="scriptName"/>
            </property>
            <property name="enabled" code="Eenb" type="boolean" access="rw" description="Whether or not the effect is currently turned on." />
            <documentation>
                <html>
                    <![CDATA[
                        <div style="margin-top:8px;background-color:#eee;padding:8px;">
                        <p>EXAMPLE SCRIPT: Apply a gaussian effect to the first layer of the current document with a radius of 5 pixels:</p>
                        <p style="font-family:Verdana,sans-serif;padding-left:6em;text-indent:-4.5em;">
                        <b>tell the first</b> <span style="color:blue;font-style:italic;">layer</span> <b>of the front</b> <span style="color:blue;font-style:italic;">document</span> <b>to</b> <span style="color:blue;"><b>make</b> new <i>gaussian effect</i> at</span> <b>the beginning of</b> <span style="color:blue;font-style:italic;">effects</span> <span style="color:blue;">with properties</span> {<span style="color:#6C05D3;">radius</span>:5}</p>
                        </div>
                    ]]>
                </html>
            </documentation>
        </class>
        <class name="gaussian effect" code="EF01" description="A gaussian blur effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingGaussianEffect"/>
            <property name="radius" code="EI01" type="real" access="rw" description="How many pixels are used to create the blur. The larger the number, the blurrier the result.">
                <cocoa key="inputRadius"/>
            </property>
        </class>
        <class name="box effect" code="EF02" description="A box blur effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingBoxEffect"/>
            <property name="radius" code="EI01" type="real" access="rw" description="How many pixels are used to create the blur. The larger the number, the blurrier the result.">
                <cocoa key="inputRadius"/>
            </property>
        </class>
        <class name="disc effect" code="EF03" description="A disc blur effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingDiscEffect"/>
            <property name="radius" code="EI01" type="real" access="rw" description="How many pixels are used to create the blur. The larger the number, the blurrier the result.">
                <cocoa key="inputRadius"/>
            </property>
        </class>
        <class name="motion effect" code="EF04" description="A motion blur effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingMotionEffect"/>
            <property name="radius" code="EI01" type="real" access="rw" description="How many pixels are used to create the blur. The larger the number, the blurrier the result.">
                <cocoa key="inputRadius"/>
            </property>
            <property name="angle" code="EI02" type="real" access="rw" description="The angle of the motion blur.">
                <cocoa key="inputAngle"/>
            </property>
        </class>
        <class name="zoom effect" code="EF05" description="A zoom blur effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingZoomEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the zoom blur effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="amount" code="EI03" type="real" access="rw" description="The intensity of the zoom blur effect.">
                <cocoa key="inputAmount"/>
            </property>
        </class>
        <class name="spin effect" code="EF06" description="A spin blur effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingSpinEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the spin blur effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="amount" code="EI03" type="integer" access="rw" description="The intensity of the spin blur effect.">
                <cocoa key="inputAmount"/>
            </property>
        </class>
        <class name="tilt shift effect" code="EF07" description="A tilt shift blur effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingTiltShiftEffect"/>
            <property name="blur" code="EI04" type="real" access="rw" description="The intensity of the tilt shift blur effect.">
                <cocoa key="inputRadius"/>
            </property>
            <property name="transition" code="EI05" type="integer" access="rw" description="The size of the transition between blurred and unblurred areas.">
                <cocoa key="inputTransition"/>
            </property>
        </class>
        <class name="focus effect" code="EF08" description="A focus blur effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingFocusEffect"/>
            <property name="blur" code="EI04" type="real" access="rw" description="The intensity of the focus blur effect.">
                <cocoa key="inputRadius"/>
            </property>
            <property name="transition" code="EI05" type="integer" access="rw" description="The size of the transition between blurred and unblurred areas.">
                <cocoa key="inputTransition"/>
            </property>
        </class>
        
        <class name="bump effect" code="EF09" description="A bump effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingBumpEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the bump effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="radius" code="EI01" type="integer" access="rw" description="The size of the area affected by the bump effect.">
                <cocoa key="inputRadius"/>
            </property>
            <property name="scale" code="Pxsc" type="integer" access="rw" description="The intensity of the bump effect.">
                <cocoa key="inputScale"/>
            </property>
        </class>
        <class name="pinch effect" code="EF10" description="A pinch effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingPinchEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the pinch effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="radius" code="EI01" type="integer" access="rw" description="The size of the area affected by the pinch effect.">
                <cocoa key="inputRadius"/>
            </property>
            <property name="scale" code="Pxsc" type="integer" access="rw" description="The intensity of the pinch effect.">
                <cocoa key="inputScale"/>
            </property>
        </class>
        <class name="circle splash effect" code="EF11" description="A circle splash effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingCircleSplashEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the circle splash effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="radius" code="EI01" type="integer" access="rw" description="The radius of the splash's center circle.">
                <cocoa key="inputRadius"/>
            </property>
        </class>
        <class name="hole effect" code="EF12" description="A hole effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingHoleEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the hole effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="radius" code="EI01" type="integer" access="rw" description="The radius of the hole.">
                <cocoa key="inputRadius"/>
            </property>
        </class>
        <class name="light tunnel effect" code="EF13" description="A light tunnel effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingLightTunnelEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the light tunnel effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="radius" code="EI01" type="integer" access="rw" description="The radius of the light tunnel effect.">
                <cocoa key="inputRadius"/>
            </property>
            <property name="rotation" code="trot" type="real" access="rw" description="The rotation of the light tunnel effec.">
                <cocoa key="inputRotation"/>
            </property>
        </class>
        <class name="twirl effect" code="EF14" description="A twirl effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingTwirlEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the twirl effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="radius" code="EI01" type="integer" access="rw" description="The radius of the twirl effect.">
                <cocoa key="inputRadius"/>
            </property>
            <property name="angle" code="EI02" type="real" access="rw" description="The angle of the twirl effect.">
                <cocoa key="inputAngle"/>
            </property>
        </class>
        <class name="vortex effect" code="EF15" description="A vortex effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingVortexEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the vortex effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="radius" code="EI01" type="integer" access="rw" description="The radius of the vortex effect.">
                <cocoa key="inputRadius"/>
            </property>
            <property name="angle" code="EI02" type="real" access="rw" description="The angle of the vortex effect.">
                <cocoa key="inputAngle"/>
            </property>
        </class>
        
        <class name="pixelate effect" code="EF16" description="A pixelate effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingPixelateEffect"/>
            <property name="scale" code="Pxsc" type="real" access="rw" description="The size of the pixels used to create the pixelation effect.">
                <cocoa key="inputScale"/>
            </property>
        </class>
        <class name="pointillize effect" code="EF17" description="A pointillize effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingPointillizeEffect"/>
            <property name="radius" code="EI01" type="real" access="rw" description="The size of the points used to create the pointillize effect.">
                <cocoa key="inputRadius"/>
            </property>
        </class>
        <class name="crystallize effect" code="EF18" description="A crystallize effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingCrystallizeEffect"/>
            <property name="radius" code="EI01" type="real" access="rw" description="The size of the crystals used to create the crystallize effect.">
                <cocoa key="inputRadius"/>
            </property>
        </class>
        
        <class name="checkerboard effect" code="EF19" description="A checkerboard effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingCheckerboardEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the center of the checkerboard effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="color 1" code="clr1" access="rw" description="The first color of the squares of the effect. Expressed as an RGB value consisting of a list of three color values from 0 to 65535. ex: Blue = {0, 0, 65535}.">
                <type type="integer" list="yes"/>
                <cocoa key="inputColor0"/>
            </property>
            <property name="color 2" code="clr2" access="rw" description="The second color of the squares of the effect. Expressed as an RGB value consisting of a list of three color values from 0 to 65535. ex: Blue = {0, 0, 65535}.">
                <type type="integer" list="yes"/>
                <cocoa key="inputColor1"/>
            </property>
            <property name="width" code="widD" type="real" access="rw" description="The size of the checkerboard's squares.">
                <cocoa key="inputWidth"/>
            </property>
            <property name="sharpness" code="Shrp" type="integer" access="rw" description="The sharpness of the edges of the squares.">
                <cocoa key="inputSharpness"/>
            </property>
            <property name="opacity" code="Opct" type="integer" description="The opacity of the checkerboard effect." access="rw">
                <cocoa key="PTEffectTypeCustomParameters.opacity"/>
            </property>
        </class>
        <class name="stripes effect" code="EF20" description="A stripes effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingStripesEffect"/>
            <property name="position" code="posn" type="point" access="rw" description="The position of the center of the stripes effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="color 1" code="clr1" access="rw" description="The first color of the stripes of the effect. Expressed as an RGB value consisting of a list of three color values from 0 to 65535. ex: Blue = {0, 0, 65535}.">
                <type type="integer" list="yes"/>
                <cocoa key="inputColor0"/>
            </property>
            <property name="color 2" code="clr2" access="rw" description="The first color of the stripes of the effect. Expressed as an RGB value consisting of a list of three color values from 0 to 65535. ex: Blue = {0, 0, 65535}.">
                <type type="integer" list="yes"/>
                <cocoa key="inputColor1"/>
            </property>
            <property name="width" code="widD" type="real" access="rw" description="The width of the stripes.">
                <cocoa key="inputWidth"/>
            </property>
            <property name="sharpness" code="Shrp" type="integer" access="rw" description="The sharpness of the edges of the stripes.">
                <cocoa key="inputSharpness"/>
            </property>
            <property name="opacity" code="Opct" type="integer" description="The opacity of the stripes effect." access="rw">
                <cocoa key="PTEffectTypeCustomParameters.opacity"/>
            </property>
        </class>
        <class name="color fill effect" code="EF21" description="A color fill effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingColorFillEffect"/>
            <property name="fill color" code="flcl" access="rw" description="The color of the color fill effect. Expressed as an RGB value consisting of a list of three color values from 0 to 65535. ex: Blue = {0, 0, 65535}.">
                <type type="integer" list="yes"/>
                <cocoa key="inputForegroundColor"/>
            </property>
        </class>
        <class name="image fill effect" code="EF22" description="An image fill effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingImageFillEffect"/>
            <property name="image" code="imaA" type="file" access="w" description="The image used for the image fill effect.">
                <cocoa key="inputFillImage"/>
            </property>
            <property name="position" code="posn" type="point" access="rw" description="The position of the center of the image fill effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="scale" code="Pxsc" type="integer" access="rw" description="The scale of the image used for the fill effect.">
                <cocoa key="inputScale"/>
            </property>
            <property name="angle" code="EI02" type="real" access="rw" description="The angle of the image used for the fill effect.">
                <cocoa key="inputAngle"/>
            </property>
            <property name="opacity" code="Opct" type="integer" description="The opacity of the image fill effect." access="rw">
                <cocoa key="PTEffectTypeCustomParameters.opacity"/>
            </property>
            <property name="blend mode" code="Lrbm" type="blend mode" description="The blend mode of the image fill effect." access="rw">
                <cocoa key="PTEffectTypeCustomParameters.blendMode"/>
            </property>
        </class>
        <class name="pattern fill effect" code="EF23" description="A pattern fill effect." inherits="effect">
            <cocoa class="Pixelmator.ScriptingPatternFillEffect"/>
            <property name="image" code="imaA" type="file" access="w" description="The image tiled to create the pattern.">
                <cocoa key="inputFillImage"/>
            </property>
            <property name="position" code="posn" type="point" access="rw" description="The position of the center of the effect.">
                <cocoa key="inputCenter"/>
            </property>
            <property name="scale" code="Pxsc" type="integer" access="rw" description="The scale of the image used to create the pattern.">
                <cocoa key="inputScale"/>
            </property>
            <property name="angle" code="EI02" type="real" access="rw" description="The angle of the image image used to create the pattern.">
                <cocoa key="inputAngle"/>
            </property>
            <property name="opacity" code="Opct" type="integer" description="The opacity of the pattern fill effect." access="rw">
                <cocoa key="PTEffectTypeCustomParameters.opacity"/>
            </property>
            <property name="blend mode" code="Lrbm" type="blend mode" description="The blend mode of the pattern fill effect." access="rw">
                <cocoa key="PTEffectTypeCustomParameters.blendMode"/>
            </property>
        </class>
    </suite>
    <suite name="Pixelmator Pro Text Suite" code="Prtx" description="Classes and commands for Pixelmator Pro text objects.">
        <enumeration name="tAHT" code="tAHT">
            <enumerator name="left" code="leTA" description="Left-align content.">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="center" code="cent" description="Center-align content.">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="right" code="riTA" description="Right-align content.">
                <cocoa integer-value="2"/>
            </enumerator>
            <enumerator name="justify" code="juTA" description="Fully justify (left and right) content.">
                <cocoa integer-value="3"/>
            </enumerator>
        </enumeration>
        <enumeration name="tAVT" code="tAVT">
            <enumerator name="top" code="topA" description="Top-align content.">
                <cocoa integer-value="0"/>
            </enumerator>
            <enumerator name="center" code="cent" description="Center-align content.">
                <cocoa integer-value="1"/>
            </enumerator>
            <enumerator name="bottom" code="botA" description="Bottom-align content.">
                <cocoa integer-value="2"/>
            </enumerator>
        </enumeration>
        <value-type name="color" code="colr">
            <cocoa class="NSColor" />
            <synonym code="cRGB" />
        </value-type>
        <class name="rich text" plural="rich text" code="rtxt" description="This provides the base rich text class for all iWork applications.">
            <cocoa class="NSTextStorage" />
            <type type="text" />
            <property name="color" code="colr" type="color" description="The color of the font. Expressed as an RGB value consisting of a list of three color values from 0 to 65535. ex: Blue = {0, 0, 65535}.">
                <cocoa key="foregroundColor" />
            </property>
            <property name="font" code="font" type="text" description="The name of the font.  Can be the PostScript name, such as: &#8220;TimesNewRomanPS-ItalicMT&#8221;, or display name: &#8220;Times New Roman Italic&#8221;. TIP: Use the Font Book application get the information about a typeface.">
                <cocoa key="fontName" />
            </property>
            <property name="size" code="ptsz" type="integer" description="The size of the font.">
                <cocoa key="fontSize" />
            </property>
            <element type="character" />
            <element type="paragraph" />
            <element type="word" />
        </class>
        <class name="character" code="cha " description="One of some text's characters." inherits="rich text">
            <cocoa class="NSTextStorage" />
            <type type="text" />
        </class>
        <class name="paragraph" code="cpar" description="One of some text's paragraphs." inherits="rich text">
            <cocoa class="NSTextStorage" />
            <type type="text" />
            <element type="character" />
            <element type="word" />
        </class>
        <class name="word" code="cwor" description="One of some text's words." inherits="rich text">
            <cocoa class="NSTextStorage" />
            <type type="text" />
            <element type="character" />
        </class>
    </suite>
</dictionary>
