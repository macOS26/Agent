            <property name="preserve transparency" code="PrTS" type="boolean" access="rw" description="Whether or not preserve transparency is enabled.">
              <cocoa key="scriptPreserveTransparency"/>
              <access-group identifier="com.pixelmatorteam.pixelmator-pro.document.edit" />
            </property>
            <property name="constrain proportions" code="CnPr" type="boolean" access="rw" description="Whether or not constrain proportions is enabled.">
