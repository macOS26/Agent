<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE dictionary SYSTEM "file://localhost/System/Library/DTDs/sdef.dtd">

<!-- declare the namespace for using XInclude so we can include the standard suite -->
<dictionary xmlns:xi="http://www.w3.org/2003/XInclude">

	<!-- use XInclude to include the standard suite -->
	<xi:include href="file:///System/Library/ScriptingDefinitions/CocoaStandard.sdef" xpointer="xpointer(/dictionary/suite)"/>

	<!-- specific suite(s) for the application follow... -->
	<suite name="Final Cut Pro Library" code="fxlm" description="Scripting terminology for Final Cut Pro Library Model.">
		<access-group identifier="com.apple.FinalCut.library.inspection" access="r"/>

		<record-type name="media time" code="cmtm">
			<property name="value" code="cmtv" type="number" description="Value of the media time.">
				<cocoa key="value"/>
			</property>
			<property name="timescale" code="cmts" type="integer" description="Timescale of the media time.">
				<cocoa key="timescale"/>
			</property>
			<property name="epoch" code="cmte" type="number" description="Epoch of the media time">
				<cocoa key="epoch"/>
			</property>
			<property name="flags" code="cmtf" type="integer" description="Flags of the media time">
				<cocoa key="flags"/>
			</property>
		</record-type>

		<enumeration name="timecode formats" code="tcfm">
			<enumerator name="unspecified" code="unsp" description="Timecode format unspecified."/>
			<enumerator name="drop frame" code="drop" description="Drop frame timecode."/>
			<enumerator name="non drop frame" code="ndrp" description="Non drop frame timecode."/>
		</enumeration>

		<class name="sequence" code="fxsq" description="A clip sequence.">
			<cocoa class="FFAnchoredSequence"/>
			<property name="name" code="pnam" type="text" access="r" description="The name of the sequence.">
				<cocoa key="displayName"/>
			</property>
			<property name="id" code="ID  " type="text" access="r" description="The unique identifier of the sequence.">
				<cocoa key="mediaIdentifier"/>
			</property>
			<property name="container" code="ctnr" type="item" access="r" descriptino="the container of the clip">
				<cocoa key="containerObject"/>
			</property>
			<property name="start time" code="pstt" type="media time" access="r" description="The start time of the sequence.">
				<cocoa key="startTimeDict"/>
			</property>
			<property name="duration" code="pdur" type="media time" access="r" description="The duration of the sequence.">
				<cocoa key="durationDict"/>
			</property>
			<property name="frame duration" code="pfrd" type="media time" access="r" description="The duration of a video frame, an inverse is the frame rate.">
				<cocoa key="frameDurationDict"/>
			</property>
			<property name="timecode format" code="ptcf" type="timecode formats" access="r" description="Timecode format, Drop Frame (DF) or Non Drop Frame (NDF).">
				<cocoa key="timecodeFormat"/>
			</property>
			<property name="essential properties" code="pESE" type="record" access="r" description="essential property of the item">
				<cocoa key="essentialProperties"/>
			</property>
		</class>

		<class name="item" code="cobj" description="an item" plural="items">
			<cocoa class="FFLibraryItem"/>
			<property name="class" code="pcls" type="type" access="r" description="the class of the item"/>
			<property name="container" code="ctnr" type="item" access="r" description="the container of the item">
				<cocoa key="containerObject"/>
			</property>
			<property name="id" code="ID  " type="text" access="r" description="the id of the item">
				<cocoa key="uniqueIdentifier"/>
			</property>
			<property name="index" code="pidx" type="integer" access="r" description="The index of the item in internal application order."/>
			<property name="name" code="pnam" type="text" description="the name of the item">
				<cocoa key="displayName"/>
			</property>
			<property name="persistent ID" code="pPIS" type="text" access="r" description="the id of the item as a hexadecimal string. This id does not change over time."/>
			<property name="properties" code="pALL" type="record" description="every property of the item"/>
			<property name="essential properties" code="pESE" type="record" access="r" description="essential property of the item">
				<cocoa key="essentialProperties"/>
			</property>
		</class>

		<class name="project" code="fxpj" description="A project." inherits="item">
			<cocoa class="FFSequenceRecord"/>
			<property name="name" code="pnam" type="text" access="r" description="The name of the project.">
				<cocoa key="displayName"/>
			</property>
			<property name="id" code="ID  " type="text" access="r" description="The unique identifier of the project.">
				<cocoa key="uniqueIdentifier"/>
			</property>
			<property name="container" code="ctnr" type="item" access="r" descriptino="the container of the project">
				<cocoa key="containerObject"/>
			</property>
			<property name="essential properties" code="pESE" type="record" access="r" description="essential property of the item">
				<cocoa key="essentialProperties"/>
			</property>
			<property name="sequence" code="pseq" type="sequence" access="r" descriptino="the sequence of the project">
				<cocoa key="sequence"/>
			</property>
		</class>

		<class name="event" code="fxev" description="An event." inherits="item">
			<cocoa class="FFEventRecord"/>
			<property name="name" code="pnam" type="text" access="r" description="The name of the event.">
				<cocoa key="displayName"/>
			</property>
			<property name="id" code="ID  " type="text" access="r" description="The unique identifier of the event.">
				<cocoa key="uniqueIdentifier"/>
			</property>
			<property name="container" code="ctnr" type="item" access="r" descriptino="the container of the project">
				<cocoa key="containerObject"/>
			</property>
			<property name="essential properties" code="pESE" type="record" access="r" description="essential property of the item">
				<cocoa key="essentialProperties"/>
			</property>
			<element type="sequence" access="r">
				<cocoa key="sequences"/>
			</element>
			<element type="project" access="r">
				<cocoa key="projects"/>
			</element>
		</class>

		<class name="library" code="fxlb" plural="libraries" description="A library."  inherits="item">
			<cocoa class="FFLibrary"/>
			<property name="name" code="pnam" type="text" access="r" description="The name of the library.">
				<cocoa key="displayName"/>
			</property>
			<property name="id" code="ID  " type="text" access="r" description="The unique identifier of the library.">
				<cocoa key="uniqueIdentifier"/>
			</property>
			<property name="container" code="ctnr" type="application" access="r" descriptino="the container of the library">
				<cocoa key="containerObject"/>
			</property>
			<property name="essential properties" code="pESE" type="record" access="r" description="essential property of the item">
				<cocoa key="essentialProperties"/>
			</property>
			<property name="file" code="file" type="file" access="r" descriptino="the file URL of the library">
				<cocoa key="URL"/>
			</property>
			<element type="event" access="r">
				<cocoa key="events"/>
			</element>
		</class>

	</suite>

	<suite name="Final Cut Pro Application" code="fxap" description="Scripting terminology for Final Cut Pro application.">

		<command name="get" code="coregetd" description="Get data.">
			<cocoa class="FFGetCommand"/>
			<access-group identifier="com.apple.FinalCut.library.inspection" access="r"/>
			<direct-parameter requires-access="r" description="Object specifier." type="specifier"/>
			<result description="The data for the object specifier." type="any"/>
		</command>

		<class-extension name="application" extends="application">
			<cocoa class="PEApplication"/>
			<property name="name" code="pnam" type="text" access="r" description="The name of the application.">
			</property>
			<element type="library" access="r" >
				<access-group identifier="com.apple.FinalCut.library.inspection" access="r"/>
				<cocoa key="libraries"/>
			</element>
		</class-extension>

	</suite>

</dictionary>
